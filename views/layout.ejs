<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Student Portal</title>

    <!-- Tailwind -->
    <script src="https://cdn.tailwindcss.com"></script>

    <!-- Fonts -->
   <style>
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');

body {
    font-family: 'Inter', sans-serif;
    background: radial-gradient(circle at top right, #1e1b4b, #020617);
    color: #e2e8f0;
}

/* ✅ Glass Effect */
.glass-card {
    background: rgba(30, 41, 59, 0.6);
    backdrop-filter: blur(14px);
    border: 1px solid rgba(139, 92, 246, 0.2);
}

/* ================= SIDEBAR ================= */
#sidebar {
    background: linear-gradient(180deg, #020617, #1e1b4b) !important;
    border-right: 1px solid rgba(139, 92, 246, 0.2) !important;
}

/* Sidebar text */
#sidebar .text-gray-800,
#sidebar .text-gray-700,
#sidebar .text-gray-600 {
    color: #cbd5f5 !important;
}

/* Hover */
#sidebar a:hover {
    background: rgba(139,92,246,0.15) !important;
    color: #a78bfa !important;
}

/* Active */
.sidebar-link-active {
    background: linear-gradient(90deg, rgba(139,92,246,0.25), transparent);
    border-left: 4px solid #a78bfa;
    color: #c4b5fd !important;
}

/* ================= HEADER ================= */
header {
    background: rgba(15, 23, 42, 0.7) !important;
    backdrop-filter: blur(10px);
    border-bottom: 1px solid rgba(139, 92, 246, 0.2);
}

/* ================= TEXT COLORS ================= */
.text-slate-200 { color: #e2e8f0 !important; }
.text-slate-300 { color: #cbd5f5 !important; }
.text-slate-400 { color: #94a3b8 !important; }
.text-slate-500 { color: #64748b !important; }

/* ================= BG FIX ================= */
.bg-slate-800 { background: #1e293b !important; }
.bg-slate-900 { background: #020617 !important; }

/* ================= HOVER ================= */
.hover\:bg-white\/5:hover {
    background: rgba(139,92,246,0.1) !important;
}

/* ================= POPUPS ================= */
#profilePopup > div,
#golu-box {
    background: rgba(15, 23, 42, 0.9) !important;
    border: 1px solid rgba(139, 92, 246, 0.2);
}

/* ================= SCROLLBAR ================= */
::-webkit-scrollbar {
    width: 6px;
}
::-webkit-scrollbar-thumb {
    background: #7c3aed;
    border-radius: 10px;
}
</style>
</head>

<body class="bg-slate-900 text-white flex">

    <!-- Sidebar -->
    <%- include('students/partials/sidebar') %>

    <div id="sidebarOverlay"
     onclick="toggleSidebar()"
     class="fixed inset-0 bg-black/40 z-40 hidden lg:hidden">
    </div>

    <!-- MAIN WRAPPER -->
    <div class="flex-1">

        <!-- HEADER -->
        <% if (showHeader) { %>
            <%- include('students/partials/header') %>
        <% } %>

        <!-- Content -->
        <main class="w-full px-3 sm:px-4 md:px-6 pb-4">

            <% if (!currentPath.startsWith('/student/dashboard')) { %>
            <!-- 📱 Mobile Back Button -->
            <div class="lg:hidden mb-3">
                <a href="/student/dashboard"
                   class="flex items-center gap-2 px-3 py-2 rounded-xl 
                          bg-gradient-to-r from-indigo-500 to-purple-500 
                          text-white text-sm font-semibold shadow-md">
                    ← Back to Dashboard
                </a>
            </div>
            <% } %>

            <%- body %>

        </main>

    </div> 

    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <script>
        lucide.createIcons();

        function toggleProfile() {
            const panel = document.getElementById("profilePanel");
            panel.classList.toggle("hidden");
        }

        document.addEventListener("click", function (e) {
            const panel = document.getElementById("profilePanel");
            const button = e.target.closest("button");

            if (!button && panel && !panel.contains(e.target)) {
                panel.classList.add("hidden");
            }
        });

        function toggleGolu() {
            const box = document.getElementById("golu-box");
            box.classList.toggle("hidden");
        }

        function toggleSidebar() {
            const sidebar = document.getElementById("sidebar");
            const overlay = document.getElementById("sidebarOverlay");

            sidebar.classList.toggle("-translate-x-full");
            overlay.classList.toggle("hidden");
        }
    </script>

</body>
</html>