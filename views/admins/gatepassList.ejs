<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Gate Pass Requests</title>

  <!-- Tailwind CDN -->
  <script src="https://cdn.tailwindcss.com"></script>

  <!-- Optional: Better font -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">

  <style>
    body {
      font-family: 'Inter', sans-serif;
    }
  </style>
</head>

<body class="bg-gradient-to-br from-[#0f172a] via-[#1e1b4b] to-[#312e81] min-h-screen text-white">

  <!-- MAIN CONTAINER -->
  <div class="max-w-6xl mx-auto py-10 px-4">

    <!-- TITLE -->
    <h1 class="text-3xl font-semibold mb-8 tracking-tight">
      🎫 Gate Pass Requests
    </h1>

    <!-- EMPTY STATE -->
    <% if (passes.length === 0) { %>
      <div class="text-center mt-20 text-slate-400 text-lg">
        No gate pass requests yet
      </div>
    <% } %>

    <!-- LIST -->
    <div class="space-y-6">

    <% passes.forEach(pass => { %>

      <div class="p-6 rounded-2xl 
                  bg-white/5 backdrop-blur-xl
                  border border-white/10
                  shadow-lg hover:shadow-purple-500/20
                  transition">

        <!-- HEADER -->
        <div class="flex justify-between items-start mb-5">

          <!-- LEFT -->
          <div class="flex items-center gap-4">

            <img src="<%= pass.studentId.profileImage || '/images/default-user.png' %>" 
                 class="w-14 h-14 rounded-full object-cover border border-white/20" />

            <div>
              <h2 class="text-lg font-semibold">
                <%= pass.studentId.fullname %>
              </h2>

              <p class="text-sm text-slate-400">
                <%= pass.studentId.course || "Course N/A" %> • Sem <%= pass.studentId.semester || "-" %>
              </p>

              <% if (pass.studentId.rollNumber) { %>
                <p class="text-xs text-slate-500 mt-1">
                  Roll: <%= pass.studentId.rollNumber %>
                </p>
              <% } %>
            </div>

          </div>

          <!-- STATUS -->
          <div>
            <% if (pass.status === "pending") { %>
              <span class="px-3 py-1 text-xs rounded-full bg-yellow-400/10 text-yellow-300 border border-yellow-400/20">
                Pending
              </span>
            <% } %>

            <% if (pass.status === "approved") { %>
              <span class="px-3 py-1 text-xs rounded-full bg-green-400/10 text-green-300 border border-green-400/20">
                Approved
              </span>
            <% } %>

            <% if (pass.status === "rejected") { %>
              <span class="px-3 py-1 text-xs rounded-full bg-red-400/10 text-red-300 border border-red-400/20">
                Rejected
              </span>
            <% } %>
          </div>

        </div>

        <!-- DETAILS -->
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 text-sm text-slate-300 mb-5">

          <div>
            <p class="text-slate-400 text-xs">Reason</p>
            <p class="mt-1"><%= pass.reason %></p>
          </div>

          <div>
            <p class="text-slate-400 text-xs">From</p>
            <p class="mt-1"><%= new Date(pass.from).toLocaleString() %></p>
          </div>

          <div>
            <p class="text-slate-400 text-xs">To</p>
            <p class="mt-1"><%= new Date(pass.to).toLocaleString() %></p>
          </div>

        </div>

        <!-- ACTION BUTTONS -->
        <% if (pass.status === "pending") { %>
          <div class="flex gap-3">

            <form action="/admin/gatepass/approve/<%= pass._id %>" method="POST" class="flex-1">
              <button class="w-full py-2.5 rounded-lg font-medium text-sm
                             bg-green-500 hover:bg-green-600
                             transition shadow-md">
                ✔ Approve
              </button>
            </form>

            <form action="/admin/gatepass/reject/<%= pass._id %>" method="POST" class="flex-1">
              <button class="w-full py-2.5 rounded-lg font-medium text-sm
                             bg-red-500 hover:bg-red-600
                             transition shadow-md">
                ✖ Reject
              </button>
            </form>

          </div>
        <% } %>

      </div>

    <% }) %>

    </div>

  </div>

</body>
</html>