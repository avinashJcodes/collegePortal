<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Pending Students</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-[#0f172a] text-white min-h-screen p-8">

  <div class="max-w-6xl mx-auto">

    <h1 class="text-3xl font-bold mb-6">
      Pending Student Requests
    </h1>

    <% if (students.length === 0) { %>
      <div class="bg-green-500/10 border border-green-500/30 p-6 rounded-xl">
        🎉 No pending requests. All students are approved.
      </div>
    <% } else { %>

      <div class="overflow-x-auto bg-slate-800 rounded-xl border border-white/10">
        <table class="w-full text-left">

          <thead class="bg-slate-900 text-gray-300">
            <tr>
              <th class="p-4">#</th>
              <th class="p-4">Full Name</th>
              <th class="p-4">Email</th>
              <th class="p-4">Admission No</th>
              <th class="p-4 text-center">Action</th>
            </tr>
          </thead>

          <tbody>
            <% students.forEach((s, index) => { %>
              <tr class="border-t border-white/10 hover:bg-slate-700/40">

                <td class="p-4"><%= index + 1 %></td>
                <td class="p-4 font-medium"><%= s.fullname %></td>
                <td class="p-4 text-gray-300"><%= s.email %></td>
                <td class="p-4"><%= s.admissionNumber %></td>

                <td class="p-4 flex gap-3 justify-center">

                  <!-- APPROVE -->
                  <form action="/admin/students/<%= s._id %>/approve" method="POST">
                    <button
                      class="bg-green-600 hover:bg-green-700 px-4 py-2 rounded-lg text-sm font-semibold">
                      Approve
                    </button>
                  </form>

                  <!-- REJECT -->
                  <form action="/admin/students/<%= s._id %>/reject" method="POST">
                    <button
                      class="bg-red-600 hover:bg-red-700 px-4 py-2 rounded-lg text-sm font-semibold">
                      Reject
                    </button>
                  </form>

                </td>
              </tr>
            <% }) %>
          </tbody>

        </table>
      </div>

    <% } %>

    <a href="/admin/dashboard"
       class="inline-block mt-6 text-purple-400 hover:underline">
      ← Back to Dashboard
    </a>

  </div>

</body>
</html>
