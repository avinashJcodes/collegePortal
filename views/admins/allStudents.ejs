<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>All Students | Admin</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900 text-white min-h-screen">

  <!-- Page Container -->
  <div class="p-8">

    <!-- Header -->
    <div class="flex items-center justify-between mb-8">
      <h1 class="text-3xl font-bold">All Students</h1>

      <a href="/admin/dashboard"
         class="text-purple-400 hover:underline text-sm">
        ← Back to Dashboard
      </a>
    </div>

    <!-- Search Bar -->
<div class="mb-6">
 <input 
  id="searchInput"
  value="<%= search || '' %>"
  type="text"
    placeholder="Search by Admission Number..." 
    class="w-full px-4 py-3 rounded-xl bg-slate-800 text-white border border-white/10 
           focus:ring-2 focus:ring-purple-500 outline-none placeholder-gray-400">
</div>

    <!-- Table Card -->
    <div class="bg-slate-800/70 backdrop-blur rounded-2xl shadow-xl overflow-hidden border border-white/10">

      <!-- Table -->
      <table class="w-full text-left">
        <thead class="bg-slate-900 text-gray-300 text-sm uppercase">
          <tr>
            <th class="px-6 py-4">Name</th>
            <th class="px-6 py-4">Admission No</th>
            <th class="px-6 py-4">Email</th>
            <th class="px-6 py-4 text-center">Status</th>
          </tr>
        </thead>

        <tbody>
          <% if (students.length === 0) { %>
            <tr>
              <td colspan="4" class="text-center py-6 text-gray-400">
                No students found
              </td>
            </tr>
          <% } %>

          <% students.forEach(student => { %>
         <tr 
  class="border-t border-white/10 hover:bg-slate-700/40 transition cursor-pointer"
  onclick="handleRowClick(event, '<%= student._id %>')"
>
              <td class="px-6 py-4 font-medium">
  <%= student.fullname %>
</td>


              <td class="px-6 py-4 text-gray-300">
                <%= student.admissionNumber || "-" %>
              </td>

              <td class="px-6 py-4 text-gray-300">
                <%= student.email %>
              </td>

              <td class="px-6 py-4 text-center">
                <% if (student.approvalStatus === "approved") { %>
                  <span class="px-3 py-1 rounded-full text-xs
                               bg-green-500/20 text-green-400 border border-green-500/30">
                    Approved
                  </span>
                <% } else if (student.approvalStatus === "pending") { %>
                  <span class="px-3 py-1 rounded-full text-xs
                               bg-yellow-500/20 text-yellow-400 border border-yellow-500/30">
                    Pending
                  </span>
                <% } else { %>
                  <span class="px-3 py-1 rounded-full text-xs
                               bg-red-500/20 text-red-400 border border-red-500/30">
                    Rejected
                  </span>
                <% } %>
              </td>

            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

  </div>

</body>
</html>

<script>
  const searchInput = document.getElementById("searchInput");
  const tbody = document.querySelector("tbody");

  let timeout;

  searchInput.addEventListener("input", () => {
    clearTimeout(timeout);

    timeout = setTimeout(async () => {
      const value = searchInput.value.trim();

      try {
        const res = await fetch("/admin/students/search?search=" + value);
        const data = await res.json();

        // 🔥 table clear
        tbody.innerHTML = "";

        if (data.length === 0) {
          tbody.innerHTML = `
            <tr>
              <td colspan="4" class="text-center py-6 text-gray-400">
                No students found
              </td>
            </tr>
          `;
          return;
        }

        // 🔥 new rows render
        data.forEach(student => {
          tbody.innerHTML += `
            <tr class="border-t border-white/10 hover:bg-slate-700/40 transition cursor-pointer"
                onclick="window.location='/admin/student/${student._id}'">

              <td class="px-6 py-4 font-medium">${student.fullname}</td>

              <td class="px-6 py-4 text-gray-300">
                ${student.admissionNumber || "-"}
              </td>

              <td class="px-6 py-4 text-gray-300">
                ${student.email}
              </td>

              <td class="px-6 py-4 text-center">
                ${
                  student.approvalStatus === "approved"
                    ? `<span class="px-3 py-1 text-xs bg-green-500/20 text-green-400 border border-green-500/30 rounded-full">Approved</span>`
                    : student.approvalStatus === "pending"
                    ? `<span class="px-3 py-1 text-xs bg-yellow-500/20 text-yellow-400 border border-yellow-500/30 rounded-full">Pending</span>`
                    : `<span class="px-3 py-1 text-xs bg-red-500/20 text-red-400 border border-red-500/30 rounded-full">Rejected</span>`
                }
              </td>
            </tr>
          `;
        });

      } catch (err) {
        console.error("Search error:", err);
      }
    }, 300);
  });
</script>
<script>
  function handleRowClick(e, id) {
    if (e.target.tagName === "INPUT") return; // 🔥 ignore input
    window.location = "/admin/student/" + id;
  }
</script>