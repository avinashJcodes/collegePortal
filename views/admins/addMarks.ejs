<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard | Student Marks Entry</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
        .glass-panel {
            background: rgba(30, 41, 59, 0.7);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.1);
        }
        input, select {
            transition: all 0.2s ease;
        }
        input:focus, select:focus {
            outline: none;
            border-color: #3b82f6;
            box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.1);
        }
        @keyframes slideUp {
            from { transform: translateY(20px); opacity: 0; }
            to { transform: translateY(0); opacity: 1; }
        }
        .animate-slide-up { animation: slideUp 0.4s ease-out forwards; }
    </style>
</head>

<body class="bg-[#0f172a] text-slate-200 min-h-screen p-4 md:p-10">

    <!-- Toast Notification Container -->
    <div id="toastContainer" class="fixed top-5 right-5 z-50 flex flex-col gap-3"></div>

    <div class="max-w-4xl mx-auto">
        <!-- Header -->
        <header class="mb-8 flex items-center justify-between">
            <div>
                <h1 class="text-3xl font-bold text-white tracking-tight flex items-center gap-3">
                    <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-blue-500"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                    Student Marks Portal
                </h1>
                <p class="text-slate-400 mt-1">Admin Management System &bull; Results Entry</p>
            </div>
            <div class="hidden md:block">
                <span class="px-3 py-1 bg-blue-500/10 border border-blue-500/20 text-blue-400 rounded-full text-sm font-medium">Academic Year 2025-26</span>
            </div>
        </header>

        <form id="marksForm" class="space-y-6">
            
            <!-- Student Information Section -->
            <div class="glass-panel rounded-2xl p-6 shadow-2xl">
                <h2 class="text-sm font-semibold uppercase tracking-wider text-slate-500 mb-6 flex items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/><path d="m9 16 2 2 4-4"/></svg>
                    Basic Information
                </h2>
                
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                    <div class="space-y-2">
                        <label class="text-sm font-medium text-slate-300">Student ID / Enrollment</label>
                        <input type="text" id="studentId" placeholder="e.g. STU9901" required 
                               class="w-full bg-slate-900/50 border border-slate-700 rounded-lg px-4 py-2.5 text-white placeholder:text-slate-600">
                               <div id="studentInfo" class="mt-2 text-sm text-green-400"></div>
                               <input type="hidden" id="studentObjectId">
                    </div>

                    <div class="space-y-2">
                        <label class="text-sm font-medium text-slate-300">Exam Type</label>
                        <select id="examType" required class="w-full bg-slate-900/50 border border-slate-700 rounded-lg px-4 py-2.5 text-white">
                            <option value="">Select Exam</option>
                            <option value="MST-1">MST-1 (Mid Semester)</option>
                            <option value="MST-2">MST-2 (Mid Semester)</option>
                            <option value="PUT">PUT (Pre-University)</option>
                        </select>
                    </div>

                    <div class="space-y-2">
                        <label class="text-sm font-medium text-slate-300">Session</label>
                        <select id="examSession" required class="w-full bg-slate-900/50 border border-slate-700 rounded-lg px-4 py-2.5 text-white text-sm">
                            <option value="WINTER">WINTER (Odd Sem)</option>
                            <option value="SUMMER">SUMMER (Even Sem)</option>
                        </select>
                    </div>

                    <div class="space-y-2">
                        <label class="text-sm font-medium text-slate-300">Semester</label>
                        <input type="number" id="semester" min="1" max="8" placeholder="1-8" required 
                               class="w-full bg-slate-900/50 border border-slate-700 rounded-lg px-4 py-2.5 text-white placeholder:text-slate-600">
                    </div>

                    <div class="space-y-2 md:col-span-2">
                        <label class="text-sm font-medium text-slate-300">Academic Year</label>
                        <input type="text" id="academicYear" value="2025-26" placeholder="YYYY-YY" required 
                               class="w-full bg-slate-900/50 border border-slate-700 rounded-lg px-4 py-2.5 text-white placeholder:text-slate-600">
                    </div>
                </div>
            </div>

            <!-- Subject Marks Section -->
            <div class="glass-panel rounded-2xl p-6 shadow-2xl">
                <div class="flex items-center justify-between mb-6">
                    <h2 class="text-sm font-semibold uppercase tracking-wider text-slate-500 flex items-center gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1-2.5-2.5Z"/><path d="M8 7h6"/><path d="M8 11h8"/></svg>
                        Subject-wise Marks
                    </h2>
                    <button type="button" id="addRowBtn" 
                            class="flex items-center gap-2 text-sm font-semibold text-blue-400 hover:text-blue-300 transition-colors bg-blue-400/10 px-3 py-1.5 rounded-lg border border-blue-400/20">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"/></svg>
                        Add Subject
                    </button>
                </div>

                <div id="subjectsContainer" class="space-y-4">
                    <!-- Dynamic Rows added here -->
                </div>

                <div class="mt-8 pt-6 border-t border-slate-700/50 flex flex-col md:flex-row items-center justify-between gap-4">
                    <div class="text-sm text-slate-400 italic">
                        * Marks will be saved as individual subject records in the database.
                    </div>
                    <button type="submit" id="submitBtn"
                            class="w-full md:w-auto bg-blue-600 hover:bg-blue-500 text-white font-bold py-3 px-10 rounded-xl transition-all shadow-lg shadow-blue-600/20 flex items-center justify-center gap-3 disabled:opacity-50 disabled:cursor-not-allowed">
                        <span id="btnText">Save All Records</span>
                        <svg id="btnIcon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
                    </button>
                </div>
            </div>
        </form>
    </div>

    <!-- Template -->
    <template id="subjectRowTemplate">
        <div class="subject-row grid grid-cols-12 gap-4 items-end bg-slate-900/30 p-4 rounded-xl border border-slate-700/30 animate-slide-up">
            <div class="col-span-12 md:col-span-7 space-y-2">
                <label class="text-xs font-semibold text-slate-500 uppercase tracking-tighter">Subject Name</label>
                <input type="text" class="subject-name w-full bg-slate-800 border border-slate-700 rounded-lg px-4 py-2 text-white" placeholder="Enter Subject Title" required>
            </div>
            <div class="col-span-8 md:col-span-4 space-y-2">
                <label class="text-xs font-semibold text-slate-500 uppercase tracking-tighter">Obtained Marks</label>
                <input type="number" class="obtained-marks w-full bg-slate-800 border border-slate-700 rounded-lg px-4 py-2 text-white" placeholder="0-100" min="0" max="100" required>
            </div>
            <div class="col-span-4 md:col-span-1 flex justify-end pb-1">
                <button type="button" class="remove-row-btn text-slate-500 hover:text-red-400 p-2 transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/><line x1="10" x2="10" y1="11" y2="17"/><line x1="14" x2="14" y1="11" y2="17"/></svg>
                </button>
            </div>
        </div>
    </template>

    <script>
        const container = document.getElementById('subjectsContainer');
        const template = document.getElementById('subjectRowTemplate');
        const addBtn = document.getElementById('addRowBtn');
        const marksForm = document.getElementById('marksForm');

        function showToast(message, type = 'success') {
            const toast = document.createElement('div');
            const bgColor = type === 'success' ? 'bg-emerald-600' : 'bg-red-600';
            toast.className = `${bgColor} text-white px-6 py-4 rounded-xl shadow-2xl animate-slide-up flex items-center gap-3 min-w-[300px] border border-white/10`;
            toast.innerHTML = `
                <span class="text-lg">${type === 'success' ? '✅' : '❌'}</span>
                <span class="font-medium">${message}</span>
            `;
            document.getElementById('toastContainer').appendChild(toast);
            setTimeout(() => {
                toast.style.opacity = '0';
                toast.style.transform = 'translateX(20px)';
                toast.style.transition = 'all 0.3s ease';
                setTimeout(() => toast.remove(), 300);
            }, 4000);
        }

        function addRow() {
            const clone = template.content.cloneNode(true);
            const removeBtn = clone.querySelector('.remove-row-btn');
            removeBtn.onclick = (e) => {
                if (document.querySelectorAll('.subject-row').length > 1) {
                    e.target.closest('.subject-row').remove();
                } else {
                    showToast("At least one subject is required", "error");
                }
            };
            container.appendChild(clone);
        }

        // Default 4 rows
        window.onload = () => { for(let i=0; i<4; i++) addRow(); };
        addBtn.onclick = addRow;

        // NEW SUBMISSION LOGIC TO FIX MONGOOSE ERROR
        marksForm.onsubmit = async (e) => {
            e.preventDefault();
            
            const submitBtn = document.getElementById('submitBtn');
            const btnText = document.getElementById('btnText');
            
            // Collect Common Data
            const commonData = {
                studentId: document.getElementById('studentObjectId').value,
                examType: document.getElementById('examType').value,
                examSession: document.getElementById('examSession').value,
                semester: document.getElementById('semester').value,
                academicYear: document.getElementById('academicYear').value
            };

            // Collect Subject Rows
            const rows = document.querySelectorAll('.subject-row');
            const records = [];
            
            rows.forEach(row => {
                const subject = row.querySelector('.subject-name').value;
                const marks = row.querySelector('.obtained-marks').value;
                if (subject && marks) {
                    records.push({ ...commonData, subject, obtainedMarks: marks });
                }
            });

            if (records.length === 0) return showToast("No subjects to save!", "error");

            // UI State: Loading
            submitBtn.disabled = true;
            btnText.innerText = "Saving Data...";

            try {
                // We send each record as a separate request to match your Mongoose Schema
                // This ensures "subject" is a String and "obtainedMarks" is a Number
                // Alternatively, you can change your backend to use insertMany()
                
                const promises = records.map(record => 
                    fetch('/admin/marks/add', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(record)
                    })
                );

                const results = await Promise.all(promises);
                const allOk = results.every(res => res.ok);

                if (allOk) {
                    showToast(`Successfully saved ${records.length} subjects!`);
                    marksForm.reset();
                    container.innerHTML = "";
                    for(let i=0; i<4; i++) addRow();
                } else {
                    throw new Error("One or more records failed to save.");
                }

            } catch (err) {
                console.error(err);
                showToast("Server Error: Check your database connection", "error");
            } finally {
                submitBtn.disabled = false;
                btnText.innerText = "Save All Records";
            }
        };
    </script>

<script>
  const input = document.getElementById("studentId");
  const info = document.getElementById("studentInfo");
  const hiddenId = document.getElementById("studentObjectId");

  let timeout;

  input.addEventListener("input", () => {
    clearTimeout(timeout);

    timeout = setTimeout(async () => {
      const value = input.value.trim();

      if (!value) {
        info.innerHTML = "";
        hiddenId.value = "";
        return;
      }

      try {
        const res = await fetch("/admin/student/search?q=" + value);
        const data = await res.json();

        if (data) {
          info.innerHTML = `✅ ${data.fullname} (Adm: ${data.admissionNumber})`;
          info.className = "mt-2 text-sm text-green-400";

          // 🔥 store actual MongoDB ID
          hiddenId.value = data._id;

        } else {
          info.innerHTML = "❌ Student not found";
          info.className = "mt-2 text-sm text-red-400";
          hiddenId.value = "";
        }
      } catch (err) {
        console.error(err);
      }
    }, 400);
  });
</script>
</body>
</html>