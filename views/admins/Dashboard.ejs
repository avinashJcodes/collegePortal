<div class="max-w-7xl">

  <div class="mb-10">
    <h1 class="text-3xl md:text-4xl font-semibold tracking-tight">
      Welcome <span class="text-purple-400"><%= adminName %></span> 👋
    </h1>
    <p class="text-slate-400 text-sm mt-2">
      Overview of your admin dashboard
    </p>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">

    <a href="/admin/students"
       class="group p-6 rounded-2xl bg-white/5 border border-white/10 hover:border-purple-500/40 transition">
      <p class="text-slate-400 text-sm">Total Students</p>
      <h2 class="text-3xl font-bold mt-3">
        <%= totalStudents %>
      </h2>
    </a>

    <div class="p-6 rounded-2xl bg-yellow-500/10 border border-yellow-500/30">
      <p class="text-yellow-400 text-sm">Pending Requests</p>
      <h2 class="text-3xl font-bold mt-3">
        <%= pendingStudents %>
      </h2>

      <% if (pendingStudents > 0) { %>
        <a href="/admin/students/pending"
           class="inline-block mt-4 text-sm text-yellow-300 hover:underline">
          Review Requests →
        </a>
      <% } %>
    </div>

    <a href="/admin/students/approved"
       class="group p-6 rounded-2xl bg-green-500/10 border border-green-500/30">
      <p class="text-green-400 text-sm">Approved Students</p>
      <h2 class="text-3xl font-bold mt-3">
        <%= approvedStudents %>
      </h2>
    </a>

  </div>

</div>