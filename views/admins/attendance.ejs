<!DOCTYPE html>
<html>
<head>
  <title>Attendance</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-slate-900 text-white p-8">

<h1 class="text-3xl font-bold mb-6 text-green-400">
  Face Recognition Attendance
</h1>

<form method="GET" action="/attendance/view"
      class="flex flex-wrap gap-4 mb-6 bg-slate-800 p-4 rounded-xl">

  <!-- Date -->
  <input type="date" name="date"
         value="<%= filters.date || '' %>"
         class="px-3 py-2 rounded bg-slate-900 border border-white/10">

  <!-- Student Name -->
  <input type="text" name="student"
         placeholder="Student Name"
         value="<%= filters.student || '' %>"
         class="px-3 py-2 rounded bg-slate-900 border border-white/10">

  <!-- Status -->
  <select name="status"
          class="px-3 py-2 rounded bg-slate-900 border border-white/10">
    <option value="">All</option>
    <option value="Present" <%= filters.status === "Present" ? "selected" : "" %>>Present</option>
    <option value="Absent" <%= filters.status === "Absent" ? "selected" : "" %>>Absent</option>
  </select>

  <button class="bg-indigo-600 px-5 py-2 rounded hover:bg-indigo-700">
    Filter
  </button>
</form>


<table class="w-full border border-white/10 rounded-xl overflow-hidden">
  <thead class="bg-slate-800">
    <tr>
      <th class="p-3">Student Name</th>
      <th class="p-3">Admission No</th>
      <th class="p-3">Date</th>
      <th class="p-3">Time</th>
      <th class="p-3">Status</th>
      <th class="p-3">Method</th>
    </tr>
  </thead>

  <tbody>

    <% records.forEach(record => { %>
      <tr class="border-t border-white/10">

        <td class="p-3 font-semibold text-indigo-300">
          <%= record.studentId ? record.studentId.fullname : "Student Deleted" %>
        </td>

        <td class="p-3 text-gray-300">
          <%= record.studentId ? record.studentId.admissionNumber : "-" %>
        </td>

        <td class="p-3">
  <%= new Date(record.date).toLocaleDateString("en-GB") %>
</td>

        <td class="p-3"><%= record.time %></td>

        <td class="p-3 font-semibold text-green-400">
          <%= record.status %>
        </td>

        <td class="p-3">
          <%= record.method %>
        </td>

      </tr>
    <% }) %>

  </tbody>
</table>

</body>
</html>