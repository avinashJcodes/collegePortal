<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Admin Login | College Portal</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>

<body class="min-h-screen flex items-center justify-center bg-gradient-to-br from-gray-900 via-black to-gray-900">

    <div class="w-full max-w-[420px] bg-[#1a1a1a]/90 backdrop-blur-xl rounded-2xl shadow-2xl border border-white/10 p-8">

        <!-- ICON -->
        <div class="flex justify-center mb-6">
            <div class="w-16 h-16 flex items-center justify-center rounded-full bg-purple-600/20 border border-purple-500">
                <i class="fa-solid fa-user-shield text-purple-400 text-2xl"></i>
            </div>
        </div>

        <!-- TITLE -->
        <div class="text-center mb-8">
            <h1 class="text-black text-2xl font-bold mb-1">Admin Login</h1>
            <p class="text-gray-600 text-sm">Authorized administrators only</p>
        </div>

        <!-- ERROR -->
        <% if (typeof error !== "undefined") { %>
            <div class="mb-4 text-sm text-red-400 bg-red-500/10 border border-red-500 rounded-lg px-4 py-2">
                <%= error %>
            </div>
        <% } %>

        <!-- FORM -->
        <form action="/admin/Login" method="POST" class="space-y-6">

            <div>
                <input type="email" name="email" required
                    placeholder="Admin Email"
                    class="w-full bg-white border border-gray-300 text-black rounded-xl py-3
                           focus:outline-none focus:border-purple-500 transition placeholder-gray-500">
            </div>

            <div class="relative">
                <input type="password" name="password" required
                    placeholder="Password"
                    class="w-full bg-white border border-gray-300 text-black rounded-xl py-3 pr-10
                           focus:outline-none focus:border-purple-500 transition placeholder-gray-500">

                <i class="fa-solid fa-lock absolute right-2 top-4 text-gray-500"></i>
            </div>

            <button type="submit"
                class="w-full bg-purple-600 hover:bg-purple-700 text-black font-semibold py-3 rounded-xl
                       shadow-lg shadow-purple-900/40 transition active:scale-95">
                Login as Admin
            </button>
        </form>

        <!-- FOOTER -->
        <div class="text-center mt-6 text-sm">
            <a href="/" class="text-gray-500 hover:text-purple-400 transition">
                ← Back to Student Login
            </a>
        </div>

    </div>

</body>
</html>
