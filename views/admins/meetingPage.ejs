<div class="flex min-h-screen bg-gradient-to-br from-[#0f172a] to-[#1e1b4b]">

  <!-- Sidebar -->
  <%- include("../admins/partials/sidebar") %>

  <!-- Main Content -->
  <div class="flex-1 flex flex-col">

    <!-- Top Bar -->
    <div class="flex justify-between items-center px-6 py-4 border-b border-white/10 bg-white/[0.03] backdrop-blur-xl">

      <div>
        <h2 class="text-white text-lg font-semibold">
          Live Meeting
        </h2>
        <p class="text-xs text-slate-400">
          Room ID: <span class="text-purple-400 font-mono"><%= meeting.roomId %></span>
        </p>
      </div>

      <div class="flex gap-3">

        <!-- Copy ID -->
        <button onclick="copyText('<%= meeting.roomId %>')" 
          class="px-4 py-2 text-xs bg-purple-600 hover:bg-purple-700 text-white rounded-lg">
          Copy ID
        </button>

        <!-- End Meeting -->
        <a href="/admin/end-meeting/<%= meeting.roomId %>" 
          class="px-4 py-2 text-xs bg-red-600 hover:bg-red-700 text-white rounded-lg">
          End Meeting
        </a>

      </div>

    </div>

    <!-- Meeting Area -->
    <div id="meet" class="flex-1"></div>

  </div>
</div>

<!-- JITSI -->
<script src="https://meet.jit.si/external_api.js"></script>

<script>
const domain = "meet.jit.si";

const options = {
  roomName: "<%= meeting.roomId %>",
  width: "100%",
  height: "100%",
  parentNode: document.querySelector("#meet"),

  userInfo: {
    displayName: "Admin"
  },

  configOverwrite: {
    startWithAudioMuted: false,
    startWithVideoMuted: false
  },

  interfaceConfigOverwrite: {
    SHOW_JITSI_WATERMARK: false
  }
};

const api = new JitsiMeetExternalAPI(domain, options);

// optional: log events
api.addEventListener("participantJoined", (p) => {
  console.log("User joined:", p);
});
</script>

<script>
function copyText(text){
  navigator.clipboard.writeText(text);

  const toast = document.createElement("div");
  toast.innerText = "Copied!";
  toast.className = "fixed bottom-5 right-5 bg-purple-600 text-white px-4 py-2 rounded shadow-lg";
  document.body.appendChild(toast);

  setTimeout(() => toast.remove(), 1500);
}
</script>