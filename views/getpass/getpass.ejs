<% if (success) { %>
  <div class="mb-4 p-3 rounded-xl bg-green-500/10 border border-green-500/20 text-green-400 shadow">
    <%= success %>
  </div>
<% } %>

<% if (error) { %>
  <div class="mb-4 p-3 rounded-xl bg-red-500/10 border border-red-500/20 text-red-400 shadow">
    <%= error %>
  </div>
<% } %>


<div class="max-w-3xl mx-auto mt-10 px-4">

  <!-- 🔥 TAB BUTTONS -->
  <div class="flex gap-4 mb-6 bg-white/5 p-2 rounded-xl backdrop-blur">

    <a href="/student/gatepass?tab=apply"
       class="flex-1 text-center py-2 rounded-lg font-medium transition
       <%= tab === 'apply' 
         ? 'bg-gradient-to-r from-purple-600 to-indigo-500 text-white shadow' 
         : 'text-slate-300 hover:bg-white/10' %>">
       Apply Pass
    </a>

    <a href="/student/gatepass?tab=history"
       class="flex-1 text-center py-2 rounded-lg font-medium transition
       <%= tab === 'history' 
         ? 'bg-gradient-to-r from-purple-600 to-indigo-500 text-white shadow' 
         : 'text-slate-300 hover:bg-white/10' %>">
       History
    </a>

  </div>


  <!-- 🔥 APPLY TAB -->
  <% if (tab === "apply") { %>

    <div class="p-6 rounded-2xl bg-gradient-to-br from-[#0f172a]/80 to-[#1e1b4b]/80 
                backdrop-blur border border-purple-500/20 shadow-xl">

      <form action="/student/gatepass/apply" method="POST" class="space-y-4">

        <input name="reason" placeholder="Reason"
          class="w-full px-4 py-2 rounded-lg bg-slate-900/70 border border-white/10 
                 text-white focus:ring-2 focus:ring-purple-500 outline-none" required />

        <input type="datetime-local" name="from"
          class="w-full px-4 py-2 rounded-lg bg-slate-900/70 border border-white/10 
                 text-white focus:ring-2 focus:ring-purple-500 outline-none" required />

        <input type="datetime-local" name="to"
          class="w-full px-4 py-2 rounded-lg bg-slate-900/70 border border-white/10 
                 text-white focus:ring-2 focus:ring-purple-500 outline-none" required />

        <button class="w-full py-2 rounded-lg font-semibold 
                       bg-gradient-to-r from-purple-600 to-indigo-500 
                       hover:from-purple-700 hover:to-indigo-600 transition shadow-lg">
          Apply Pass
        </button>

      </form>

    </div>

  <% } %>


  <!-- 🔥 HISTORY TAB -->
  <% if (tab === "history") { %>

    <% if (passes.length === 0) { %>
      <p class="text-center text-slate-400">No requests yet</p>
    <% } %>

    <% const current = passes[0]; %>

    <!-- CURRENT -->
    <% if (current) { %>
      <div class="mb-6 p-5 rounded-2xl bg-purple-500/10 border border-purple-500/20 shadow">

        <p class="font-semibold text-white mb-2">Current Status</p>

        <% if (current.status === "pending") { %>
          <p class="text-yellow-400">⏳ Waiting for approval...</p>
        <% } %>

        <% if (current.status === "approved") { %>

          <div class="p-6 rounded-2xl 
                      bg-gradient-to-br from-green-500/10 to-emerald-500/10
                      border border-green-500/20 shadow-lg mt-3">

            <h2 class="text-green-400 text-xl font-bold mb-3">
              🎫 Gate Pass Approved
            </h2>

            <div class="text-slate-200 space-y-2">
              <p><b>Pass ID:</b> <%= current.passId %></p>
              <p><b>Reason:</b> <%= current.reason %></p>
              <p><b>From:</b> <%= new Date(current.from).toLocaleString() %></p>
              <p><b>To:</b> <%= new Date(current.to).toLocaleString() %></p>
            </div>

            <% if (current.qrCode) { %>
              <div class="mt-4 flex justify-center">
                <img src="<%= current.qrCode %>" class="w-40 rounded-xl shadow-lg border border-white/10" />
              </div>
            <% } %>

            <% if (new Date() > new Date(current.to)) { %>
              <p class="text-red-400 mt-3 text-center">❌ Pass Expired</p>
            <% } else { %>
              <p class="text-green-300 mt-3 text-center">✅ Show this pass at gate</p>
            <% } %>

          </div>

        <% } %>

        <% if (current.status === "rejected") { %>
          <p class="text-red-400">❌ Request Rejected</p>
        <% } %>

      </div>
    <% } %>


    <!-- HISTORY -->
    <div class="space-y-3">

      <% passes.forEach(pass => { %>

        <div class="p-4 rounded-xl bg-white/5 border border-white/10 
                    hover:bg-white/10 transition">

          <div class="flex justify-between items-center">

            <p class="text-white font-medium">
              <%= pass.reason %>
            </p>

            <% if (pass.status === "pending") { %>
              <span class="text-xs px-2 py-1 rounded bg-yellow-500/20 text-yellow-400">Pending</span>
            <% } %>

            <% if (pass.status === "approved") { %>
              <span class="text-xs px-2 py-1 rounded bg-green-500/20 text-green-400">Approved</span>
            <% } %>

            <% if (pass.status === "rejected") { %>
              <span class="text-xs px-2 py-1 rounded bg-red-500/20 text-red-400">Rejected</span>
            <% } %>

          </div>

          <p class="text-sm text-slate-400 mt-1">
            <%= new Date(pass.from).toLocaleString() %> → 
            <%= new Date(pass.to).toLocaleString() %>
          </p>

        </div>

      <% }) %>

    </div>

  <% } %>

</div>