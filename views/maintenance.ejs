<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Launching Soon | A New Experience</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;600;800&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: #020617;
            color: #f8fafc;
            overflow-x: hidden;
        }

        /* Animated Background Glows */
        .glow {
            position: absolute;
            width: 40vw;
            height: 40vw;
            border-radius: 50%;
            filter: blur(80px);
            z-index: -1;
            opacity: 0.4;
            animation: float 20s infinite alternate;
        }

        @keyframes float {
            0% { transform: translate(0, 0); }
            100% { transform: translate(10vw, 10vh); }
        }

        .glass {
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.8);
        }

        .neon-text {
            text-shadow: 0 0 15px rgba(96, 165, 250, 0.5);
        }

        .input-glow:focus {
            box-shadow: 0 0 20px rgba(96, 165, 250, 0.2);
            border-color: rgba(96, 165, 250, 0.5);
        }

        @keyframes pulse-border {
            0%, 100% { border-color: rgba(96, 165, 250, 0.3); }
            50% { border-color: rgba(139, 92, 246, 0.6); }
        }

        .timer-box {
            animation: pulse-border 4s infinite;
        }
    </style>
</head>
<body class="min-h-screen flex items-center justify-center relative px-4 py-12">

    <!-- Background Elements -->
    <div class="glow bg-blue-600 top-[-10%] left-[-10%]"></div>
    <div class="glow bg-purple-600 bottom-[-10%] right-[-10%] animate-delay-1000" style="animation-delay: -5s;"></div>

    <div class="max-w-4xl w-full text-center z-10">
        
        <!-- Proactive Header for First Time Launch -->
        <div class="mb-12">
            <div class="inline-block px-4 py-1.5 rounded-full border border-blue-500/30 bg-blue-500/10 text-blue-400 text-sm font-semibold mb-6 tracking-wide uppercase">
                🚀 New Platform Launching Soon
            </div>
            <h1 class="text-6xl md:text-8xl font-extrabold tracking-tighter mb-6 neon-text">
                Live in <span id="main-days-display" class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-violet-400">29 Days.</span>
            </h1>
            <p class="text-gray-400 text-lg md:text-xl max-w-2xl mx-auto font-light leading-relaxed">
                Something extraordinary is being built. We are preparing to launch our brand new website to give you the best experience from day one.
            </p>
        </div>

        <!-- Stylish Timer -->
        <div class="flex flex-wrap justify-center gap-4 md:gap-8 mb-16">
            <div class="glass timer-box rounded-3xl p-6 w-28 md:w-36">
                <span id="days" class="block text-4xl md:text-5xl font-bold text-white mb-1">00</span>
                <span class="text-blue-400 text-[10px] font-bold uppercase tracking-widest">Days</span>
            </div>
            <div class="glass timer-box rounded-3xl p-6 w-28 md:w-36">
                <span id="hours" class="block text-4xl md:text-5xl font-bold text-white mb-1">00</span>
                <span class="text-blue-400 text-[10px] font-bold uppercase tracking-widest">Hours</span>
            </div>
            <div class="glass timer-box rounded-3xl p-6 w-28 md:w-36">
                <span id="minutes" class="block text-4xl md:text-5xl font-bold text-white mb-1">00</span>
                <span class="text-blue-400 text-[10px] font-bold uppercase tracking-widest">Mins</span>
            </div>
            <div class="glass timer-box rounded-3xl p-6 w-28 md:w-36">
                <span id="seconds" class="block text-4xl md:text-5xl font-bold text-white mb-1">00</span>
                <span class="text-blue-400 text-[10px] font-bold uppercase tracking-widest">Secs</span>
            </div>
        </div>

        <!-- Waitlist / Notify Form -->
        <div class="max-w-lg mx-auto mb-16 px-4">
            <div id="notify-form" class="relative">
                <div class="flex flex-col sm:flex-row gap-3">
                    <input 
                        type="email" 
                        id="email-input"
                        placeholder="Join the waitlist" 
                        class="flex-1 bg-white/5 border border-white/10 rounded-2xl px-6 py-4 outline-none text-white placeholder-gray-500 input-glow transition-all"
                    >
                    <button 
                        onclick="handleSubscribe()"
                        class="bg-blue-600 hover:bg-blue-500 text-white font-bold px-8 py-4 rounded-2xl transition-all hover:scale-105 active:scale-95 shadow-lg shadow-blue-600/20"
                    >
                        Notify Me
                    </button>
                </div>
            </div>

            <!-- Modern Success Message -->
            <div id="success-message" class="hidden">
                <div class="glass border-emerald-500/30 bg-emerald-500/5 p-6 rounded-3xl flex items-center justify-center space-x-4">
                    <div class="h-10 w-10 bg-emerald-500 rounded-full flex items-center justify-center shadow-lg shadow-emerald-500/40">
                        <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" /></svg>
                    </div>
                    <div class="text-left">
                        <p class="font-bold text-white uppercase tracking-tight">Successfully added!</p>
                        <p class="text-emerald-400/80 text-sm">We will notify you.</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Contact Section -->
        <div class="max-w-lg mx-auto">
            <p class="text-gray-500 text-xs font-bold uppercase tracking-[0.2em] mb-3">Get in touch</p>
            <a href="mailto:avinashjadhav80100@gmail.com" class="inline-flex items-center space-x-2 text-blue-400 hover:text-blue-300 transition-colors">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                <span class="text-lg font-semibold tracking-tight">avinashjadhav80100@gmail.com</span>
            </a>
        </div>

        <!-- Footer -->
        <div class="mt-16 text-gray-600 text-[10px] tracking-widest uppercase">
            &copy; 2024 NEXTGEN DIGITAL SOLUTIONS • ALL RIGHTS RESERVED
        </div>
    </div>

    <script>
        /** * FIX: We set a specific target date so it doesn't reset on refresh.
         * Target: May 9, 2026 (29 days from April 10, 2026)
         */
        const countdownDate = new Date("May 9, 2026 00:00:00").getTime();

        function updateTimer() {
            const now = new Date().getTime();
            const distance = countdownDate - now;

            // If the date has passed
            if (distance < 0) {
                document.getElementById('days').innerText = "00";
                document.getElementById('hours').innerText = "00";
                document.getElementById('minutes').innerText = "00";
                document.getElementById('seconds').innerText = "00";
                document.getElementById('main-days-display').innerText = "WE ARE LIVE!";
                return;
            }

            const d = Math.floor(distance / (1000 * 60 * 60 * 24));
            const h = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
            const m = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
            const s = Math.floor((distance % (1000 * 60)) / 1000);

            document.getElementById('days').innerText = String(d).padStart(2, '0');
            document.getElementById('hours').innerText = String(h).padStart(2, '0');
            document.getElementById('minutes').innerText = String(m).padStart(2, '0');
            document.getElementById('seconds').innerText = String(s).padStart(2, '0');
            
            // Sync the main heading display too
            document.getElementById('main-days-display').innerText = d + " Days.";
        }

        setInterval(updateTimer, 1000);
        updateTimer();

        // Notification Script
        function handleSubscribe() {
            const email = document.getElementById('email-input').value;
            const form = document.getElementById('notify-form');
            const success = document.getElementById('success-message');

            if (email.trim() !== "" && email.includes('@')) {
                form.classList.add('opacity-0', 'pointer-events-none', 'scale-95');
                setTimeout(() => {
                    form.classList.add('hidden');
                    success.classList.remove('hidden');
                    success.style.animation = 'float 1s ease-out';
                }, 300);
            } else {
                const input = document.getElementById('email-input');
                input.classList.add('border-red-500/50', 'bg-red-500/5');
                setTimeout(() => input.classList.remove('border-red-500/50', 'bg-red-500/5'), 1500);
            }
        }
    </script>
</body>
</html>   