<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Support Chat | Academic Portal</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap');
        
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: #0f172a;
            background-image: 
                radial-gradient(at 0% 0%, rgba(79, 70, 229, 0.15) 0px, transparent 50%),
                radial-gradient(at 100% 100%, rgba(99, 102, 241, 0.1) 0px, transparent 50%);
        }

        .chat-window {
            height: calc(100vh - 120px);
            max-height: 800px;
        }

        .custom-scrollbar::-webkit-scrollbar {
            width: 5px;
        }
        .custom-scrollbar::-webkit-scrollbar-track {
            background: transparent;
        }
        .custom-scrollbar::-webkit-scrollbar-thumb {
            background: rgba(255, 255, 255, 0.1);
            border-radius: 20px;
        }
        .custom-scrollbar::-webkit-scrollbar-thumb:hover {
            background: rgba(255, 255, 255, 0.2);
        }

        .message-in {
            animation: messageSlide 0.3s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }

        @keyframes messageSlide {
            from { opacity: 0; transform: translateY(10px) scale(0.98); }
            to { opacity: 1; transform: translateY(0) scale(1); }
        }

        .glass-card {
            background: rgba(15, 23, 42, 0.6);
            backdrop-filter: blur(24px);
            border: 1px solid rgba(255, 255, 255, 0.08);
        }

        .user-gradient {
            background: linear-gradient(135deg, #4f46e5 0%, #6366f1 100%);
        }
    </style>
</head>

<body class="text-slate-200 min-h-screen flex items-center justify-center p-4 md:p-8">

    <div class="w-full max-w-4xl glass-card rounded-[2.5rem] shadow-[0_32px_64px_-16px_rgba(0,0,0,0.5)] overflow-hidden flex flex-col md:flex-row">
        
        <!-- ================= SIDEBAR (DESKTOP ONLY) ================= -->
        <div class="hidden md:flex w-72 flex-col border-r border-white/5 bg-black/20 p-6">
            <div class="mb-8">
                <div class="flex items-center gap-3 mb-6">
                    <div class="w-10 h-10 rounded-xl bg-indigo-500/10 flex items-center justify-center border border-indigo-500/20">
                        <i data-lucide="sparkles" class="w-5 h-5 text-indigo-400"></i>
                    </div>
                    <span class="font-bold text-lg tracking-tight">Portal Help</span>
                </div>
                <div class="space-y-1">
                    <button class="w-full flex items-center gap-3 px-4 py-3 rounded-xl bg-white/5 text-indigo-400 font-medium transition-all border border-white/5">
                        <i data-lucide="message-square" class="w-4 h-4"></i>
                        Live Support
                    </button>
                    <button class="w-full flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-white/5 text-slate-400 hover:text-slate-200 transition-all">
                        <i data-lucide="book-open" class="w-4 h-4"></i>
                        Knowledge Base
                    </button>
                </div>
            </div>
            
            <div class="mt-auto p-4 rounded-2xl bg-indigo-500/5 border border-indigo-500/10">
                <p class="text-[11px] font-bold text-indigo-300 uppercase tracking-widest mb-2">Priority Account</p>
                <p class="text-xs text-slate-400 leading-relaxed">Your queries are routed to our senior academic advisors.</p>
            </div>
        </div>

        <!-- ================= MAIN CHAT AREA ================= -->
        <div class="flex-grow flex flex-col relative">
            
            <!-- HEADER -->
            <div class="px-8 py-6 flex items-center justify-between border-b border-white/5 bg-white/[0.02]">
                <div class="flex items-center gap-4">
                    <div class="relative">
                        <div class="w-12 h-12 bg-slate-800 rounded-2xl flex items-center justify-center border border-white/10">
                            <i data-lucide="user-round" class="text-slate-400 w-6 h-6"></i>
                        </div>
                        <span class="absolute -bottom-1 -right-1 w-4 h-4 bg-emerald-500 border-[3px] border-[#0f172a] rounded-full"></span>
                    </div>
                    <div>
                        <h2 class="text-base font-bold text-white tracking-tight">Academic Advisor</h2>
                        <div class="flex items-center gap-1.5">
                            <p class="text-[11px] font-medium text-emerald-400">Typical reply: 5 mins</p>
                        </div>
                    </div>
                </div>
                <div class="flex items-center gap-2">
                    <button class="p-2.5 rounded-xl hover:bg-white/5 text-slate-400 transition-all border border-transparent hover:border-white/5">
                        <i data-lucide="info" class="w-5 h-5"></i>
                    </button>
                </div>
            </div>

            <!-- MESSAGES -->
            <div id="messageContainer" class="chat-window overflow-y-auto p-8 space-y-8 custom-scrollbar">
                
                <div class="flex flex-col items-center gap-4 mb-8">
                    <div class="w-px h-12 bg-gradient-to-b from-transparent to-white/10"></div>
                    <span class="px-4 py-1.5 rounded-full bg-white/5 border border-white/10 text-[10px] text-slate-500 font-bold uppercase tracking-[0.2em]">
                        Secure Session Initialized
                    </span>
                </div>

                <% messages.forEach(msg => { %>
                    <div class="flex <%= msg.sender === 'student' ? 'justify-end' : 'justify-start' %> group message-in">
                        <div class="max-w-[85%] md:max-w-[75%] flex flex-col <%= msg.sender === 'student' ? 'items-end' : 'items-start' %>">
                            
                            <% if (msg.status === 'deleted' || msg.isDeleted) { %>
                                <div class="px-5 py-3 rounded-2xl text-xs italic text-slate-500 bg-white/5 border border-white/5 flex items-center gap-2">
                                    <i data-lucide="circle-off" class="w-3 h-3"></i>
                                    Message retracted
                                </div>
                            <% } else { %>
                                <div class="relative group/bubble flex items-center gap-3">
                                    
                                    <!-- Delete Button (Left side for student messages) -->
                                    <% if (msg.sender === 'student') { %>
                                        <form action="/student/chat/delete/<%= msg._id %>" method="POST" class="opacity-0 group-hover/bubble:opacity-100 transition-all translate-x-2 group-hover/bubble:translate-x-0">
                                            <button type="submit" class="w-8 h-8 flex items-center justify-center text-slate-500 hover:text-rose-400 hover:bg-rose-500/10 rounded-lg transition-all" title="Delete">
                                                <i data-lucide="trash-2" class="w-4 h-4"></i>
                                            </button>
                                        </form>
                                    <% } %>

                                    <div class="px-5 py-4 rounded-[1.5rem] text-[14px] leading-relaxed shadow-2xl
                                        <%= msg.sender === 'student' 
                                            ? 'user-gradient text-white rounded-br-none shadow-indigo-500/20' 
                                            : 'bg-slate-800/80 text-slate-200 rounded-bl-none border border-white/5 shadow-black/20' %>">
                                        <%= msg.message %>
                                    </div>
                                </div>
                                <span class="mt-2 text-[10px] font-medium text-slate-600 uppercase tracking-tighter px-1">
                                    <%= msg.sender === 'student' ? 'Sent' : 'Advisor' %>
                                </span>
                            <% } %>
                        </div>
                    </div>
                <% }) %>

            </div>

            <!-- INPUT BOX -->
            <div class="p-8 mt-auto">
                <div class="bg-white/5 border border-white/10 rounded-[2rem] p-2 pr-3 focus-within:border-indigo-500/50 transition-all backdrop-blur-md">
                    <form method="POST" class="flex items-center gap-2">
                        <input
                            name="message"
                            type="text"
                            placeholder="Describe your issue..."
                            class="flex-grow px-6 py-4 bg-transparent outline-none text-sm text-white placeholder:text-slate-500"
                            required
                            autocomplete="off"
                        />
                        
                        <div class="flex items-center gap-1">
                            <button type="button" class="p-3 text-slate-500 hover:text-slate-300 transition-colors">
                                <i data-lucide="image" class="w-5 h-5"></i>
                            </button>
                            <button class="bg-white hover:bg-indigo-50 text-slate-950 w-12 h-12 rounded-[1.25rem] flex items-center justify-center transition-all active:scale-90 shadow-xl">
                                <i data-lucide="send-horizontal" class="w-5 h-5"></i>
                            </button>
                        </div>
                    </form>
                </div>
                <div class="flex justify-between items-center mt-4 px-4">
                    <p class="text-[10px] text-slate-600 font-bold uppercase tracking-widest flex items-center gap-2">
                        <span class="w-1 h-1 rounded-full bg-slate-600"></span>
                        End-to-end encrypted
                    </p>
                    <p class="text-[10px] text-slate-600 font-bold uppercase tracking-widest">
                        Academic Portal v2.4
                    </p>
                </div>
            </div>

        </div>
    </div>

    <!-- ================= SCRIPTS ================= -->
    <script>
        lucide.createIcons();

        const container = document.getElementById('messageContainer');
        const scrollToEnd = () => {
            container.scrollTo({
                top: container.scrollHeight,
                behavior: 'smooth'
            });
        };
        
        scrollToEnd();

        // Maintain scroll position after form submission
        document.querySelector('form').addEventListener('submit', () => {
            setTimeout(scrollToEnd, 100);
        });
    </script>

    <!-- Socket.io Logic -->
    <script src="/socket.io/socket.io.js"></script>
    <script>
      const socket = io();
      const roomId = "<%= student._id %>";
      socket.emit("joinRoom", roomId);

      const form = document.querySelector("form");
      const input = document.querySelector("input[name='message']");

      form.addEventListener("submit", (e) => {
        socket.emit("sendMessage", {
          room: roomId,
          sender: "student",
          message: input.value
        });
      });

      socket.on("receiveMessage", () => {
        location.reload();
      });
    </script>

</body>
</html> 