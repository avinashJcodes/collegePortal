<!DOCTYPE html>

<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Exam Fee Payment</title>

```
<script src="https://cdn.tailwindcss.com"></script>

<!-- ✅ Cashfree SDK (TOP PE RAKHO) -->
<script src="https://sdk.cashfree.com/js/v3/cashfree.js"></script>
```

</head>

<body class="bg-gray-100 min-h-screen flex items-center justify-center">

<div class="bg-white p-8 rounded-xl shadow-md w-full max-w-md text-center">

```
<h2 class="text-2xl font-bold mb-4">Exam Fee Payment</h2>

<p class="text-gray-600 mb-2"><b>Name:</b> <%= student.fullname %></p>
<p class="text-gray-600 mb-2"><b>Email:</b> <%= student.email %></p>
<p class="text-gray-600 mb-2"><b>Course:</b> <%= form.course %></p>
<p class="text-gray-600 mb-2"><b>Semester:</b> <%= form.semester %></p>

<div class="mt-6 mb-6">
    <p class="text-xl font-bold text-green-600">
        ₹ <%= form.examFee %>
    </p>
</div>

<button id="payBtn"
    class="w-full bg-blue-600 hover:bg-blue-700 text-white py-3 rounded-lg font-semibold">
    Confirm & Pay Now
</button>

<p id="msg" class="mt-4 text-sm text-red-500"></p>
```

</div>

<script>
/* =========================
   SAFE WAIT FOR SDK
========================= */
function waitForCashfree() {
    return new Promise(resolve => {
        if (window.Cashfree) return resolve();

        const interval = setInterval(() => {
            if (window.Cashfree) {
                clearInterval(interval);
                resolve();
            }
        }, 50);
    });
}

/* =========================
   MAIN PAYMENT FUNCTION
========================= */
async function payNow() {

    const btn = document.getElementById("payBtn");
    const msg = document.getElementById("msg");

    try {
        btn.disabled = true;
        btn.innerText = "Processing...";

        // ✅ ensure SDK loaded
        await waitForCashfree();

        // ✅ create order
        const res = await fetch("/exam/student/cashfree/create-order/<%= form._id %>", {
            method: "POST",
            credentials: "include"
        });

        if (!res.ok) throw new Error("Server error");

        const data = await res.json();

        console.log("PAYMENT DATA:", data);

        if (!data.payment_session_id) {
            throw new Error("No session id received");
        }

        // ✅ correct SDK usage
        const cashfree = window.Cashfree({
            mode: "production"
        });

        // ✅ open checkout
        await cashfree.checkout({
            paymentSessionId: data.payment_session_id
        });

    } catch (err) {
        console.error("❌ Payment Error:", err);
        msg.innerText = "Payment failed. Try again.";
    } finally {
        btn.disabled = false;
        btn.innerText = "Confirm & Pay Now";
    }
}

/* =========================
   EVENT BIND (NO onclick)
========================= */
window.addEventListener("DOMContentLoaded", () => {
    document.getElementById("payBtn").addEventListener("click", payNow);
});
</script>

</body>
</html>
