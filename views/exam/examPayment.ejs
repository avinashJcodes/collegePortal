<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Exam Fee Payment Portal - Avi Nagpur</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f8fafc;
        }
        .gradient-bg {
            background: linear-gradient(135deg, #1e3a8a 0%, #1e40af 100%);
        }
    </style>
</head>
<body class="min-h-screen flex flex-col">

    <!-- Top Navigation Header -->
    <header class="gradient-bg text-white shadow-lg">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center py-4">
                <div class="flex items-center space-x-4">
                    <!-- Placeholder for Logo -->
                    <div class="w-12 h-12 bg-white rounded-full flex items-center justify-center text-blue-900 font-bold text-xl">
                        NIT
                    </div>
                    <div>
                        <h1 class="text-xl md:text-2xl font-bold tracking-tight">AVI INSTITUTE OF TECHNOLOGY</h1>
                        <p class="text-blue-100 text-xs md:text-sm uppercase tracking-widest font-medium">Examination Payment Portal</p>
                    </div>
                </div>
                <div class="hidden md:block text-right">
                    <p class="text-xs text-blue-200 uppercase">Session</p>
                    <p class="font-semibold">Winter 2026-2027</p>
                </div>
            </div>
        </div>
    </header>

    <!-- Main Content Area -->
    <main class="flex-grow max-w-7xl mx-auto w-full px-4 sm:px-6 lg:px-8 py-8">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            
            <!-- Left Side: Student & Exam Details -->
            <div class="lg:col-span-2 space-y-6">
                <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
                    <div class="px-6 py-4 border-b border-gray-100 bg-gray-50 flex items-center justify-between">
                        <h2 class="text-lg font-bold text-gray-800 flex items-center">
                            <svg class="w-5 h-5 mr-2 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                            </svg>
                            Student Information
                        </h2>
                        <span class="text-xs font-bold text-blue-600 bg-blue-50 px-3 py-1 rounded-full uppercase">Verified Student</span>
                    </div>
                    
                    <div class="p-6 grid grid-cols-1 md:grid-cols-2 gap-8">
                        <div>
                            <label class="text-xs font-bold text-gray-400 uppercase tracking-wider">Full Name</label>
                            <p class="text-lg font-semibold text-gray-800 mt-1"><%= student.fullname %></p>
                        </div>
                        <div>
                            <label class="text-xs font-bold text-gray-400 uppercase tracking-wider">Email Address</label>
                            <p class="text-lg font-semibold text-gray-800 mt-1"><%= student.email %></p>
                        </div>
                        <div>
                            <label class="text-xs font-bold text-gray-400 uppercase tracking-wider">Course / Branch</label>
                            <p class="text-lg font-semibold text-gray-800 mt-1"><%= form.course %></p>
                        </div>
                        <div>
                            <label class="text-xs font-bold text-gray-400 uppercase tracking-wider">Semester</label>
                            <p class="text-lg font-semibold text-gray-800 mt-1"><%= form.semester %></p>
                        </div>
                    </div>
                </div>

                <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
                    <div class="px-6 py-4 border-b border-gray-100 bg-gray-50">
                        <h2 class="text-lg font-bold text-gray-800 flex items-center">
                            <svg class="w-5 h-5 mr-2 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                            </svg>
                            Exam Details
                        </h2>
                    </div>
                    <div class="p-6 grid grid-cols-1 md:grid-cols-2 gap-8">
                        <div>
                            <label class="text-xs font-bold text-gray-400 uppercase tracking-wider">Examination Name</label>
                            <p class="text-lg font-semibold text-gray-800 mt-1"><%= form.examName %></p>
                        </div>
                        <div>
                            <label class="text-xs font-bold text-gray-400 uppercase tracking-wider">Attempt Type</label>
                            <p class="text-lg font-semibold text-gray-800 mt-1">
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-sm font-medium bg-purple-100 text-purple-800">
                                    <%= form.examType%>
                                </span>
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right Side: Payment Summary -->
            <div class="lg:col-span-1">
                <div class="bg-white rounded-2xl shadow-md border border-gray-100 sticky top-8 overflow-hidden">
                    <div class="px-6 py-6 border-b border-gray-100">
                        <h2 class="text-xl font-bold text-gray-800">Payment Summary</h2>
                    </div>
                    
                    <div class="p-6 space-y-4">
                        <div class="flex justify-between text-gray-600">
                            <span>Exam Fee</span>
                            <span class="font-medium text-gray-900">₹<%= form.examFee %></span>
                        </div>
                        <div class="flex justify-between text-gray-600">
                            <span>Processing Charges</span>
                            <span class="font-medium text-green-600">₹0.00</span>
                        </div>
                        
                        <div class="pt-4 border-t border-dashed border-gray-200">
                            <div class="flex justify-between items-center">
                                <span class="text-lg font-bold text-gray-800">Total Payable</span>
                                <span class="text-3xl font-extrabold text-blue-700">₹<%= form.examFee %></span>
                            </div>
                        </div>

                        <!-- Status Alert -->
                        <div id="statusMessage" class="hidden p-3 rounded-lg text-sm text-center"></div>

                        <button id="payBtn" onclick="payNow()" class="w-full mt-6 bg-blue-600 hover:bg-blue-700 text-white font-bold py-4 rounded-xl transition-all duration-200 shadow-lg flex items-center justify-center space-x-2 group">
                            <span>Confirm & Pay Now</span>
                            <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                            </svg>
                        </button>

                        <div class="flex flex-col items-center space-y-2 mt-6">
                            <div class="flex items-center space-x-2 grayscale opacity-50 hover:grayscale-0 hover:opacity-100 transition-all">
                                <img src="https://www.cashfree.com/wp-content/uploads/2022/10/cashfree-logo.png" alt="Cashfree" class="h-4">
                            </div>
                            <p class="text-[10px] text-gray-400 text-center px-4 leading-relaxed">
                                By clicking 'Confirm & Pay Now', you agree to the Examination Terms and Conditions of AVI Nagpur.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <!-- Footer -->
    <footer class="py-6 border-t border-gray-200 mt-auto bg-white">
        <div class="max-w-7xl mx-auto px-4 text-center">
            <p class="text-sm text-gray-500">&copy; 2025 AVI Institute of Technology. All Rights Reserved.</p>
        </div>
    </footer>

    <!-- Cashfree SDK -->
    <script src="https://sdk.cashfree.com/js/v3/cashfree.js"></script>

    <script>
        const statusEl = document.getElementById('statusMessage');
        const payBtn = document.getElementById('payBtn');

        function showMessage(msg, isError = true) {
            statusEl.textContent = msg;
            statusEl.className = isError 
                ? 'p-3 rounded-lg text-sm text-center bg-red-100 text-red-700 block' 
                : 'p-3 rounded-lg text-sm text-center bg-blue-100 text-blue-700 block';
        }

        function payNow() {
            // UI Feedback
            payBtn.disabled = true;
            payBtn.innerHTML = `
                <svg class="animate-spin h-5 w-5 mr-3 text-white" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                </svg>
                Processing...
            `;
            payBtn.classList.add('opacity-75', 'cursor-not-allowed');

            fetch("/exam/student/cashfree/create-order/<%= form._id %>", {
                method: "POST"
            })
            .then(res => res.json())
            .then(data => {
                if (!data.payment_session_id) {
                    showMessage("Payment session failed. Please refresh the page.");
                    resetButton();
                    return;
                }

                const cashfree = new Cashfree({
                    mode: "sandbox" // Change to "production" for live
                });

                cashfree.checkout({
                    paymentSessionId: data.payment_session_id
                });
            })
            .catch(err => {
                console.error("❌ Error", err);
                showMessage("A connection error occurred.");
                resetButton();
            });
        }

        function resetButton() {
            payBtn.disabled = false;
            payBtn.innerHTML = `
                <span>Confirm & Pay Now</span>
                <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                </svg>
            `;
            payBtn.classList.remove('opacity-75', 'cursor-not-allowed');
        }
    </script>
</body>
</html>