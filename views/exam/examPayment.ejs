<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Exam Fee Payment</title>

    <script src="https://cdn.tailwindcss.com"></script>

    <!-- ✅ Cashfree SDK -->
    <script src="https://sdk.cashfree.com/js/v3/cashfree.js"></script>
</head>

<body class="bg-gradient-to-br from-gray-900 via-black to-gray-900 min-h-screen">

<!-- ✅ CENTER WRAPPER -->
<div class="min-h-screen flex items-center justify-center px-4">

    <!-- ✅ FIXED WIDTH (IMPORTANT) -->
    <div class="w-full max-w-md">

        <div class="bg-white/5 backdrop-blur-xl border border-white/10 
                    rounded-2xl shadow-2xl p-8 text-center">

            <!-- ICON -->
            <div class="flex justify-center mb-6">
                <div class="w-16 h-16 flex items-center justify-center rounded-full 
                            bg-purple-600/20 border border-purple-500 shadow-lg shadow-purple-500/30">
                    💳
                </div>
            </div>

            <!-- TITLE -->
            <h2 class="text-2xl font-bold text-white mb-2">
                Exam Fee Payment
            </h2>
            <p class="text-gray-400 text-sm mb-6">
                Secure payment via Cashfree
            </p>

            <!-- DETAILS -->
            <div class="bg-white/5 rounded-xl p-5 space-y-3 text-left border border-white/10">

                <p class="text-gray-300 text-sm flex justify-between">
                    <span class="text-gray-500">Name:</span>
                    <span class="text-white font-semibold"><%= student.fullname %></span>
                </p>

                <p class="text-gray-300 text-sm flex justify-between">
                    <span class="text-gray-500">Email:</span>
                    <span class="text-white font-semibold"><%= student.email %></span>
                </p>

                <p class="text-gray-300 text-sm flex justify-between">
                    <span class="text-gray-500">Course:</span>
                    <span class="text-white font-semibold"><%= form.course %></span>
                </p>

                <p class="text-gray-300 text-sm flex justify-between">
                    <span class="text-gray-500">Semester:</span>
                    <span class="text-white font-semibold"><%= form.semester %></span>
                </p>

            </div>

            <!-- AMOUNT -->
            <div class="mt-6 mb-6">
                <p class="text-gray-400 text-sm">Total Amount</p>
                <p class="text-3xl font-bold text-purple-400">
                    ₹ <%= form.examFee %>
                </p>
            </div>

            <!-- BUTTON -->
            <button id="payBtn"
                class="w-full bg-gradient-to-r from-purple-600 to-pink-600 
                       hover:scale-[1.03] active:scale-[0.96]
                       text-white font-bold py-3 rounded-xl
                       shadow-lg shadow-purple-500/30
                       transition-all duration-300">
                Confirm & Pay Now
            </button>

            <!-- MESSAGE -->
            <p id="msg" class="mt-4 text-sm text-red-400"></p>

        </div>

    </div>

</div>

<script>
function waitForCashfree() {
    return new Promise(resolve => {
        if (window.Cashfree) return resolve();

        const interval = setInterval(() => {
            if (window.Cashfree) {
                clearInterval(interval);
                resolve();
            }
        }, 50);
    });
}

async function payNow() {
    const btn = document.getElementById("payBtn");
    const msg = document.getElementById("msg");

    try {
        btn.disabled = true;
        btn.innerText = "Processing...";

        await waitForCashfree();

        const res = await fetch("/exam/student/cashfree/create-order/<%= form._id %>", {
            method: "POST",
            credentials: "include"
        });

        if (!res.ok) throw new Error("Server error");

        const data = await res.json();

        if (!data.payment_session_id) {
            throw new Error("No session id received");
        }

        const cashfree = window.Cashfree({
            mode: "production"
        });

        await cashfree.checkout({
            paymentSessionId: data.payment_session_id
        });

    } catch (err) {
        console.error("❌ Payment Error:", err);
        msg.innerText = "Payment failed. Try again.";
    } finally {
        btn.disabled = false;
        btn.innerText = "Confirm & Pay Now";
    }
}

window.addEventListener("DOMContentLoaded", () => {
    document.getElementById("payBtn").addEventListener("click", payNow);
});
</script>

</body>
</html>