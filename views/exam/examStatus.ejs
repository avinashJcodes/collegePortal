<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
    <title>Exam Application Status</title>
</head>
<body class="bg-[#0f172a] text-slate-200 min-h-screen font-sans">

    <div class="max-w-3xl mx-auto px-4 py-12">
        <!-- Back Navigation -->


        <!-- Header Section -->
        <div class="mb-10 text-center sm:text-left">
            <h1 class="text-4xl font-extrabold tracking-tight text-white mb-2">Application Status</h1>
            <p class="text-slate-400 text-lg">View and track the payment status of your exam forms.</p>
        </div>

        <!-- Logic Implementation -->
        <div class="space-y-4">
            <% if (forms.length === 0) { %>
                <!-- Empty State -->
                <div class="flex flex-col items-center justify-center p-12 bg-slate-800/40 border border-slate-700/50 rounded-2xl">
                    <div class="bg-slate-700/50 p-4 rounded-full mb-4">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-slate-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                        </svg>
                    </div>
                    <p class="text-slate-400 font-medium text-lg">No exam forms found.</p>
                    <p class="text-slate-500 text-sm mt-1">You haven't submitted any applications yet.</p>
                </div>
            <% } %>

            <% forms.forEach(f => { %>
                <!-- Form Card -->
                <div class="group relative bg-slate-800/50 border border-slate-700 hover:border-indigo-500/50 transition-all duration-300 rounded-xl overflow-hidden p-5 sm:p-6 shadow-xl">
                    
                    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
                        <div class="space-y-1">
                            <span class="text-xs font-semibold uppercase tracking-wider text-indigo-400">Exam Name</span>
                            <h2 class="text-xl font-bold text-white group-hover:text-indigo-300 transition-colors">
                                <%= f.examName %>
                            </h2>
                        </div>

                        <div class="flex items-center">
                            <% if (f.paymentStatus === "Paid") { %>
                                <div class="inline-flex items-center px-3 py-1 rounded-full bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 text-sm font-bold">
                                    <span class="relative flex h-2 w-2 mr-2">
                                        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                                        <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
                                    </span>
                                    PAID
                                </div>
                            <% } else { %>
                                <div class="inline-flex items-center px-3 py-1 rounded-full bg-amber-500/10 border border-amber-500/20 text-amber-400 text-sm font-bold">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                                    </svg>
                                    PENDING
                                </div>
                            <% } %>
                        </div>
                    </div>

                    <% if (f.paymentStatus === "Paid") { %>
                        <div class="mt-6 pt-5 border-t border-slate-700/50 flex flex-col sm:flex-row sm:items-center justify-between gap-4">
                            <div class="flex items-center text-sm text-slate-400">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-2 text-slate-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                                </svg>
                                <span class="mr-1">Paid on:</span>
                                <span class="text-slate-300 font-medium"><%= new Date(f.paidAt).toLocaleString("en-IN") %></span>
                            </div>

                            <div class="flex items-center bg-slate-900/50 px-3 py-1.5 rounded-lg border border-slate-700/30 text-xs">
                                <span class="text-slate-500 mr-2 uppercase font-semibold">Transaction ID:</span>
                                <code class="text-indigo-300 font-mono tracking-tighter"><%= f.transactionId %></code>
                            </div>
                        </div>
                    <% } %>
                </div>
            <% }) %>
        </div>

        <div class="mt-8 text-center border-t border-slate-800 pt-8">
            <p class="text-slate-500 text-sm italic">Showing status for <%= forms.length %> active applications</p>
        </div>
    </div>

</body>
</html>