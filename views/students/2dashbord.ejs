
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AVI Institute | Engineering Excellence</title>
    
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- Iconify Icons -->
    <script src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js"></script>
    
    <!-- React & ReactDOM -->
    <script crossorigin src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
    <script crossorigin src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
    
    <!-- Babel -->
    <script crossorigin src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
    
    <!-- Lenis Smooth Scroll -->
    <script src="https://unpkg.com/@studio-freight/lenis@1.0.33/dist/lenis.min.js"></script>

    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --bg-base: #03000a;
            --accent-primary: #a855f7;
            --accent-secondary: #c084fc;
            --glass-border: rgba(168, 85, 247, 0.15);
        }

        /* Lenis Smooth Scroll Recommended Base */
        html.lenis { height: auto; }
        .lenis.lenis-smooth { scroll-behavior: auto; }
        .lenis.lenis-smooth [data-lenis-prevent] { overscroll-behavior: contain; }
        .lenis.lenis-stopped { overflow: hidden; }
        .lenis.lenis-scrolling iframe { pointer-events: none; }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: var(--bg-base);
            color: #f8fafc;
            -webkit-font-smoothing: antialiased;
            overflow-x: hidden;
        }

        h1, h2, h3, .font-heading {
            font-family: 'Outfit', sans-serif;
        }

        /* Sophisticated Glassmorphism */
        .glass-header {
            background: rgba(10, 2, 25, 0.6);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border-bottom: 1px solid var(--glass-border);
        }

        .glass-card {
            background: rgba(255, 255, 255, 0.02);
            backdrop-filter: blur(12px);
            border: 1px solid var(--glass-border);
            transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
            position: relative;
            overflow: hidden;
        }

        .glass-card:hover {
            background: rgba(255, 255, 255, 0.05);
            border-color: rgba(168, 85, 247, 0.4);
            transform: translateY(-8px);
            box-shadow: 0 30px 60px -20px rgba(0, 0, 0, 0.8), 0 0 20px rgba(168, 85, 247, 0.1);
        }

        /* The "Lens" Spotlight Effect */
        .spotlight-lens {
            position: fixed;
            width: 800px;
            height: 800px;
            background: radial-gradient(circle, rgba(147, 51, 234, 0.1) 0%, transparent 70%);
            border-radius: 50%;
            z-index: 0;
            pointer-events: none;
            transition: transform 0.1s ease-out;
        }

        /* Text Gradients */
        .text-purple-gradient {
            background: linear-gradient(135deg, #fff 0%, #a855f7 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        /* Premium Grain Overlay */
        .grain-overlay {
            position: fixed;
            inset: 0;
            z-index: 99;
            pointer-events: none;
            opacity: 0.03;
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
        }

        /* Interactive Buttons */
        .btn-purple {
            background: linear-gradient(135deg, #9333ea 0%, #6366f1 100%);
            box-shadow: 0 10px 20px -5px rgba(147, 51, 234, 0.5);
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
        }
        .btn-purple:hover {
            transform: translateY(-2px);
            box-shadow: 0 15px 30px -5px rgba(147, 51, 234, 0.7);
        }
        .btn-purple::after {
            content: '';
            position: absolute;
            top: -50%; left: -50%;
            width: 200%; height: 200%;
            background: radial-gradient(circle, rgba(255,255,255,0.2) 0%, transparent 60%);
            opacity: 0;
            transition: opacity 0.3s;
        }
        .btn-purple:hover::after { opacity: 1; }

        /* Custom Scrollbar */
        ::-webkit-scrollbar { width: 5px; }
        ::-webkit-scrollbar-track { background: #03000a; }
        ::-webkit-scrollbar-thumb { background: #4c1d95; border-radius: 10px; }

        @keyframes marquee {
            0% { transform: translateX(0); }
            100% { transform: translateX(-50%); }
        }
        .animate-marquee {
            animation: marquee 30s linear infinite;
        }
    </style>
</head>
<body class="selection:bg-purple-500/30">

    <div class="grain-overlay"></div>
    <div id="root"></div>

    <script type="text/babel">
        const { useState, useEffect } = React;

        const App = () => {
            const [isScrolled, setIsScrolled] = useState(false);
            const [mousePos, setMousePos] = useState({ x: 0, y: 0 });

            useEffect(() => {
                // Initialize Lenis Smooth Scroll
                const lenis = new Lenis({
                    duration: 1.2,
                    easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
                    direction: 'vertical',
                    gestureDirection: 'vertical',
                    smooth: true,
                    mouseMultiplier: 1,
                    smoothTouch: false,
                    touchMultiplier: 2,
                    infinite: false,
                });

                function raf(time) {
                    lenis.raf(time);
                    requestAnimationFrame(raf);
                }
                requestAnimationFrame(raf);

                const handleScroll = () => setIsScrolled(window.scrollY > 20);
                const handleMouseMove = (e) => setMousePos({ x: e.clientX, y: e.clientY });

                window.addEventListener('scroll', handleScroll);
                window.addEventListener('mousemove', handleMouseMove);

                return () => {
                    window.removeEventListener('scroll', handleScroll);
                    window.removeEventListener('mousemove', handleMouseMove);
                };
            }, []);

            return (
                <div className="flex flex-col min-h-screen relative overflow-x-hidden">
                    {/* The Lens Spotlight */}
                    <div 
                        className="spotlight-lens" 
                        style={{ transform: `translate(${mousePos.x - 400}px, ${mousePos.y - 400}px)` }}
                    ></div>

                    {/* Header */}
                    <header className={`fixed top-0 z-50 w-full transition-all duration-500 ${isScrolled ? 'glass-header py-3' : 'bg-transparent py-7'}`}>
                        <div className="max-w-7xl mx-auto px-6 lg:px-8">
                            <div className="flex items-center justify-between">
                                {/* Logo */}
                                <div className="flex items-center gap-4 group cursor-pointer">
                                    <div className="w-10 h-10 bg-purple-600 rounded-xl flex items-center justify-center shadow-[0_0_30px_rgba(168,85,247,0.5)] group-hover:rotate-12 transition-transform relative overflow-hidden">
                                        <div className="absolute inset-0 bg-gradient-to-tr from-white/30 to-transparent"></div>
                                        <span className="text-white font-black text-xl z-10">V</span>
                                    </div>
                                    <div className="flex flex-col">
                                        <span className="text-lg font-black tracking-tight text-white leading-none uppercase">AVI TECH</span>
                                        <span className="text-[10px] font-bold text-purple-400 uppercase tracking-[0.3em] mt-1 block">Nagpur Node</span>
                                    </div>
                                </div>
                                
                                {/* Desktop Nav */}
                                <nav className="hidden md:flex items-center space-x-10">
                                    {['Home', 'About', 'Courses', 'Admissions', 'Placements'].map((item) => (
                                        <a key={item} href={item === 'Home' ? '#' : `#${item.toLowerCase()}`} 
                                           className="text-[11px] font-black text-slate-400 hover:text-purple-400 uppercase tracking-[0.2em] transition-colors relative group">
                                            {item}
                                            <span className="absolute -bottom-1.5 left-0 w-0 h-[2px] bg-purple-500 transition-all group-hover:w-full"></span>
                                        </a>
                                    ))}
                                </nav>

                                {/* CTA */}
                                <div className="flex items-center gap-5">
                                    <a href="/register"
                                       className="px-6 py-2.5 bg-white/5 border border-white/10 rounded-full text-[10px] font-black text-white uppercase tracking-[0.2em] hover:bg-white/10 transition-all">
                                        Login
                                    </a>
                                </div>
                            </div>
                        </div>
                    </header>

                    <main className="flex-grow flex flex-col">
                        {/* Hero Section */}
                        <section className="relative min-h-screen flex items-center pt-24 overflow-hidden bg-black">
                            {/* Professional Background Overlay */}
                            <div className="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1517245386807-bb43f82c33c4?ixlib=rb-4.0.3&auto=format&fit=crop&w=1920&q=80')] bg-cover bg-center opacity-20 grayscale"></div>
                            <div className="absolute inset-0 bg-gradient-to-t from-[#03000a] via-transparent to-[#03000a]"></div>
                            <div className="absolute inset-0 bg-[#03000a]/60"></div>
                            
                            <div className="relative max-w-7xl mx-auto px-6 lg:px-8 w-full flex flex-col items-center text-center">
                                <div className="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-purple-500/10 border border-purple-500/20 text-purple-400 text-[10px] font-black uppercase tracking-[0.3em] mb-12">
                                    <span className="flex h-2 w-2 rounded-full bg-purple-500 animate-ping"></span>
                                    System Intake: Session 2026-27 Active
                                </div>
                                <h1 className="text-6xl md:text-8xl xl:text-9xl font-black tracking-tighter text-white leading-[0.8] mb-10 uppercase">
                                    Architecting <br/>
                                    <span className="text-purple-gradient">The Future.</span>
                                </h1>
                                <p className="mt-6 text-lg md:text-xl text-slate-400 max-w-3xl mx-auto font-medium leading-relaxed">
                                    Join an elite node of engineering excellence. Theoretical mastery meets industrial rigor at Nagpur's premier research institute.
                                </p>
                                
                                <div className="mt-14 flex flex-col sm:flex-row items-center justify-center gap-8">
                                    <a href="/admission" className="btn-purple px-12 py-5 rounded-full text-[11px] font-black text-white uppercase tracking-[0.2em] active:scale-95 shadow-2xl">
                                        Initialize Application 🚀
                                    </a>
                                    <a href="#courses" className="px-10 py-5 rounded-full border border-white/10 bg-white/5 backdrop-blur-md text-[11px] font-black text-white uppercase tracking-[0.2em] hover:bg-white/10 transition-all">
                                        Technical Catalog
                                    </a>
                                </div>
                            </div>
                        </section>

                        {/* Bento Features Section */}
                        <section className="py-40 bg-[#03000a] relative">
                            <div className="max-w-7xl mx-auto px-6 lg:px-8">
                                <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
                                    {[
                                        { icon: "solar:users-group-rounded-bold", title: "Elite Faculty", desc: "Mentorship from PhD fellows and FAANG industrial veterans." },
                                        { icon: "solar:city-bold", title: "Quantum Labs", desc: "Advanced facilities for Robotics, AI, and Neural Research." },
                                        { icon: "solar:briefcase-bold", title: "MNC Pipelines", desc: "Direct recruitment tracks with global fortune 500 tech firms." },
                                        { icon: "solar:lightbulb-bold", title: "R&D Node", desc: "Dedicated funding to transform student prototypes into startups." }
                                    ].map((f, i) => (
                                        <div key={i} className="glass-card p-10 rounded-[2.5rem] flex flex-col h-full group">
                                            <div className="w-14 h-14 rounded-2xl bg-purple-600/10 border border-purple-600/20 flex items-center justify-center mb-8 text-purple-400 transition-all group-hover:scale-110 group-hover:bg-purple-600 group-hover:text-white group-hover:shadow-[0_0_30px_rgba(168,85,247,0.4)]">
                                                <iconify-icon icon={f.icon} class="text-3xl"></iconify-icon>
                                            </div>
                                            <h3 className="text-xl font-black text-white mb-4 tracking-tight uppercase">{f.title}</h3>
                                            <p className="text-sm text-slate-500 leading-relaxed font-medium">{f.desc}</p>
                                        </div>
                                    ))}
                                </div>
                            </div>
                        </section>

                        {/* About Section */}
                        <section id="about" className="py-40 bg-slate-950 relative overflow-hidden">
                            <div className="max-w-7xl mx-auto px-6 lg:px-8 relative z-10">
                                <div className="grid lg:grid-cols-2 gap-24 items-center">
                                    <div className="order-2 lg:order-1">
                                        <div className="grid gap-6">
                                            <div className="glass-card p-10 rounded-[3rem]">
                                                <div className="flex items-center gap-5 mb-6">
                                                    <div className="p-3 bg-purple-500/10 rounded-xl">
                                                        <iconify-icon icon="solar:target-bold" class="text-4xl text-purple-500"></iconify-icon>
                                                    </div>
                                                    <h4 className="text-2xl font-black text-white tracking-tight">Our Mission</h4>
                                                </div>
                                                <p className="text-base text-slate-400 leading-relaxed font-medium">To architect technical leaders with global sensibilities and unwavering ethical foundations.</p>
                                            </div>
                                            <div className="glass-card p-10 rounded-[3rem] bg-purple-600/5 border-purple-500/20 translate-x-6">
                                                <div className="flex items-center gap-5 mb-6">
                                                    <div className="p-3 bg-indigo-500/10 rounded-xl">
                                                        <iconify-icon icon="solar:eye-bold" class="text-4xl text-indigo-400"></iconify-icon>
                                                    </div>
                                                    <h4 className="text-2xl font-black text-white tracking-tight">Our Vision</h4>
                                                </div>
                                                <p className="text-base text-slate-400 leading-relaxed font-medium">To be the global benchmark for technical research and industrial socio-economic transformation.</p>
                                            </div>
                                        </div>
                                    </div>
                                    <div className="order-1 lg:order-2">
                                        <span className="text-[11px] font-black text-purple-500 uppercase tracking-[0.5em] mb-6 block">Institutional Legacy</span>
                                        <h2 className="text-5xl md:text-7xl font-black text-white mb-10 tracking-tighter leading-none uppercase">Academic <br/>Authority.</h2>
                                        <p className="text-xl text-slate-400 mb-10 leading-relaxed font-medium">
                                            Since 2005, AVI Institute has been Nagpur's epicenter for technical evolution. We integrate theoretical mastery with industrial application to ensure our graduates lead the digital frontier.
                                        </p>
                                        <a href="#" className="inline-flex items-center gap-3 text-[11px] font-black text-purple-400 uppercase tracking-[0.3em] group">
                                            VIEW_REPOSITORY <iconify-icon icon="solar:arrow-right-linear" class="text-lg group-hover:translate-x-2 transition-transform"></iconify-icon>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </section>

                        {/* Infinite Brand Marquee */}
                        <section className="py-24 border-y border-white/5 bg-black/40 overflow-hidden">
                            <div className="flex gap-24 items-center animate-marquee whitespace-nowrap opacity-10 grayscale hover:opacity-100 transition-all duration-1000 cursor-default">
                                {['MICROSOFT', 'GOOGLE', 'AMAZON', 'NVIDIA', 'TESLA', 'INTEL', 'APPLE', 'META'].map(brand => (
                                    <span key={brand} className="text-4xl font-black text-white tracking-tighter">{brand}</span>
                                ))}
                                {['MICROSOFT', 'GOOGLE', 'AMAZON', 'NVIDIA', 'TESLA', 'INTEL', 'APPLE', 'META'].map(brand => (
                                    <span key={brand + '2'} className="text-4xl font-black text-white tracking-tighter">{brand}</span>
                                ))}
                            </div>
                        </section>

                        {/* Portal Access */}
                        <section className="py-40 bg-[#03000a]">
                            <div className="max-w-7xl mx-auto px-6 lg:px-8">
                                <div className="glass-card p-16 md:p-24 rounded-[4rem] bg-gradient-to-tr from-purple-950/20 via-[#03000a] to-blue-950/10 flex flex-col md:flex-row items-center justify-between gap-16 relative">
                                    <div className="absolute top-0 right-0 w-64 h-64 bg-purple-600/5 blur-[100px]"></div>
                                    <div className="text-center md:text-left">
                                        <h2 className="text-4xl md:text-5xl font-black text-white mb-6 tracking-tight uppercase">Centralized <br/>Command Node.</h2>
                                        <p className="text-slate-400 text-lg font-medium">Single-sign-on access for academic records, <br/>merit analytics, and research modules.</p>
                                    </div>
                                    <div className="flex gap-6 flex-wrap justify-center">
                                        <button className="px-10 py-5 bg-white text-black font-black text-[11px] uppercase tracking-[0.2em] rounded-full hover:scale-105 transition-all shadow-xl shadow-white/10">Dashboard</button>
                                        <button className="px-10 py-5 border border-white/10 text-white font-black text-[11px] uppercase tracking-[0.2em] rounded-full hover:bg-white/5 transition-all">Support_Cell</button>
                                    </div>
                                </div>
                            </div>
                        </section>
                    </main>

                    {/* Industrial Footer */}
                    <footer className="bg-slate-950 py-32 border-t border-white/5">
                        <div className="max-w-7xl mx-auto px-6 lg:px-8">
                            <div className="grid grid-cols-1 md:grid-cols-4 gap-20 mb-24">
                                <div className="col-span-1 md:col-span-1">
                                    <div className="flex items-center gap-4 mb-8">
                                        <div className="w-9 h-9 bg-purple-600 rounded-lg flex items-center justify-center">
                                            <span className="text-white font-black text-xs">V</span>
                                        </div>
                                        <span className="text-xl font-black text-white tracking-[0.2em] uppercase">AVI TECH</span>
                                    </div>
                                    <p className="text-[11px] text-slate-500 font-bold uppercase tracking-widest leading-loose">
                                        Defining high-performance engineering for the next century. ISO 9001:2015 Accredited Technical Node.
                                    </p>
                                </div>

                                {['System', 'Enrollment', 'Academy'].map(title => (
                                    <div key={title}>
                                        <h3 className="text-[11px] font-black text-white mb-10 uppercase tracking-[0.4em] text-purple-500">{title}</h3>
                                        <ul className="space-y-5">
                                            {['Link Node 01', 'Link Node 02', 'Link Node 03'].map(link => (
                                                <li key={link}><a href="#" className="text-[11px] font-bold text-slate-500 hover:text-purple-400 transition-colors uppercase tracking-widest">{link}</a></li>
                                            ))}
                                        </ul>
                                    </div>
                                ))}
                            </div>

                            <div className="pt-12 border-t border-white/5 flex flex-col md:flex-row items-center justify-between gap-8 opacity-20">
                                <p className="text-[10px] font-black uppercase tracking-[0.5em] text-slate-500">
                                    © 2026 AVI Institute. Engineering Framework v6.0.2
                                </p>
                                <div className="flex gap-10 text-white">
                                    <iconify-icon icon="solar:global-linear" class="text-2xl hover:text-purple-400 cursor-pointer transition-colors"></iconify-icon>
                                    <iconify-icon icon="solar:link-linear" class="text-2xl hover:text-purple-400 cursor-pointer transition-colors"></iconify-icon>
                                </div>
                            </div>
                        </div>
                    </footer>
                </div>
            );
        };

        const root = ReactDOM.createRoot(document.getElementById('root'));
        root.render(<App />);
    </script>

</body>
</html>