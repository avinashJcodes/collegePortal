<aside id="sidebar"
class="fixed lg:sticky top-0 left-0 z-50
       w-72 h-screen
       bg-gradient-to-b from-slate-950 via-slate-900 to-slate-950
       backdrop-blur-xl
       border-r border-white/5
       px-5 py-8
       transform -translate-x-full
       lg:translate-x-0
       transition-transform duration-300
       flex flex-col">

    <!-- 🔥 LOGO -->
    <div class="mb-10 px-2 flex items-center gap-3">
        <div class="w-11 h-11 bg-gradient-to-br from-indigo-500 to-cyan-500 
                    rounded-2xl flex items-center justify-center 
                    shadow-lg shadow-indigo-500/30">
            <i data-lucide="graduation-cap" class="text-white w-6 h-6"></i>
        </div>
        <div>
            <h2 class="text-lg font-bold bg-gradient-to-r from-indigo-400 to-cyan-400 bg-clip-text text-transparent">
                Nexus Student
            </h2>
            <p class="text-[10px] uppercase tracking-widest text-slate-500 font-bold">
                Portal v2.0
            </p>
        </div>
    </div>

    <!-- MENU -->
    <nav class="space-y-2 flex-1">

        <p class="text-[10px] uppercase tracking-widest text-slate-500 font-bold mb-4 px-3">
            Main Menu
        </p>

        <!-- 🔥 LINK STYLE -->
        <% const baseClass = "group flex items-center gap-3 px-4 py-3 rounded-xl transition-all duration-200"; %>

        <!-- DASHBOARD -->
        <a href="/student/dashboard"
        class="<%= baseClass %> 
        <%= currentPath.startsWith('/student/dashboard') 
            ? 'bg-gradient-to-r from-indigo-500/20 to-transparent text-indigo-400 shadow-inner' 
            : 'text-slate-400 hover:bg-white/5 hover:text-white hover:translate-x-1' %>">
            
            <i data-lucide="layout-dashboard" class="w-5 h-5 group-hover:scale-110 transition"></i>
            Dashboard
        </a>

        <!-- NOTICES -->
        <a href="/student/notices"
        class="<%= baseClass %> 
        <%= currentPath.startsWith('/student/notices') 
            ? 'bg-gradient-to-r from-indigo-500/20 to-transparent text-indigo-400 shadow-inner' 
            : 'text-slate-400 hover:bg-white/5 hover:text-white hover:translate-x-1' %>">
            
            <i data-lucide="bell" class="w-5 h-5 group-hover:scale-110 transition"></i>
            Notices
        </a>

        <!-- MARKS -->
        <a href="/marks/marks"
        class="<%= baseClass %> 
        <%= currentPath.startsWith('/marks') 
            ? 'bg-gradient-to-r from-indigo-500/20 to-transparent text-indigo-400 shadow-inner' 
            : 'text-slate-400 hover:bg-white/5 hover:text-white hover:translate-x-1' %>">
            
            <i data-lucide="file-text" class="w-5 h-5 group-hover:scale-110 transition"></i>
            Marks
        </a>

        <!-- ATTENDANCE -->
        <a href="/attendance/student"
        class="<%= baseClass %> 
        <%= currentPath.startsWith('/attendance') 
            ? 'bg-gradient-to-r from-indigo-500/20 to-transparent text-indigo-400 shadow-inner' 
            : 'text-slate-400 hover:bg-white/5 hover:text-white hover:translate-x-1' %>">
            
            <i data-lucide="calendar-check" class="w-5 h-5 group-hover:scale-110 transition"></i>
            Attendance
        </a>

        <!-- EXAM -->
        <a href="/exam/student/exam-form"
        class="<%= baseClass %> 
        <%= currentPath.startsWith('/exam') 
            ? 'bg-gradient-to-r from-indigo-500/20 to-transparent text-indigo-400 shadow-inner' 
            : 'text-slate-400 hover:bg-white/5 hover:text-white hover:translate-x-1' %>">
            
            <i data-lucide="calendar" class="w-5 h-5 group-hover:scale-110 transition"></i>
            Exam
        </a>

        <!-- PROFILE -->
        <a href="/student/profile"
        class="<%= baseClass %> 
        <%= currentPath.startsWith('/student/profile') 
            ? 'bg-gradient-to-r from-indigo-500/20 to-transparent text-indigo-400 shadow-inner' 
            : 'text-slate-400 hover:bg-white/5 hover:text-white hover:translate-x-1' %>">
            
            <i data-lucide="user-circle" class="w-5 h-5 group-hover:scale-110 transition"></i>
            Profile
        </a>

        <!-- CHAT -->
        <a href="/student/chat"
        class="<%= baseClass %> 
        <%= currentPath.startsWith('/student/chat') 
            ? 'bg-gradient-to-r from-indigo-500/20 to-transparent text-indigo-400 shadow-inner' 
            : 'text-slate-400 hover:bg-white/5 hover:text-white hover:translate-x-1' %>">
            
            <i data-lucide="messages-square" class="w-5 h-5 group-hover:scale-110 transition"></i>
            Chat
        </a>

        <a href="/meeting/joinmeeting"
   class="<%= baseClass %> 
   <%= currentPath.startsWith('/student/join-meeting') 
       ? 'bg-gradient-to-r from-purple-500/20 to-transparent text-purple-400 shadow-inner' 
       : 'text-slate-400 hover:bg-white/5 hover:text-white hover:translate-x-1' %>">
       
    <i data-lucide="video" class="w-5 h-5 group-hover:scale-110 transition"></i>
    Meeting
</a>

        <!-- LOGOUT -->
        <a href="/student/logout"
        class="flex items-center gap-3 px-4 py-3 rounded-xl 
               text-red-400 hover:bg-red-500/10 hover:text-red-500 transition-all">
            
            <i data-lucide="log-out" class="w-5 h-5"></i>
            Logout
        </a>

    </nav>

</aside>