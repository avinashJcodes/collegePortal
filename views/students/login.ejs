<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AVI Student Portal </title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: { sans: ['Plus Jakarta Sans', 'sans-serif'] },
                    animation: {
                        'float': 'float 6s ease-in-out infinite',
                        'login-pulse': 'loginPulse 4s ease-in-out infinite',
                    },
                    keyframes: {
                        float: { 
                            '0%, 100%': { transform: 'translateY(0px)' },
                            '50%': { transform: 'translateY(-10px)' }
                        },
                        loginPulse: {
                            '0%, 100%': { transform: 'scale(1)', opacity: 0.8 },
                            '50%': { transform: 'scale(1.02)', opacity: 1 }
                        }
                    }
                }
            }
        }
    </script>
    <style>
        #aurora-canvas {
            position: fixed;
            top: 0; left: 0;
            width: 100%; height: 100%;
            z-index: -1;
        }
        .glass {
            background: rgba(15, 12, 25, 0.6);
            backdrop-filter: blur(25px);
            -webkit-backdrop-filter: blur(25px);
            border: 1px solid rgba(255, 255, 255, 0.08);
        }
        .gradient-border {
            position: relative;
            background: rgba(255, 255, 255, 0.03);
        }
        .gradient-border::before {
            content: '';
            position: absolute;
            inset: 0;
            padding: 1.5px;
            background: linear-gradient(135deg, #4f46e5, #8b5cf6, #ec4899);
            border-radius: inherit;
            mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
            mask-composite: xor;
            -webkit-mask-composite: xor;
        }
        
        /* Sliding Logic matching your script.js (slide-register class) */
        .wrapper {
            display: flex;
            width: 200%;
            transition: transform 0.8s cubic-bezier(0.65, 0, 0.35, 1);
        }
        /* Dashboard slide logic: slide-register moves the wrapper to left */
        .wrapper.slide-register {
            transform: translateX(-50%);
        }
        .form-panel { width: 50%; display: flex; }

        .input-field {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.1);
            transition: all 0.3s ease;
        }
        .input-field:focus {
            border-color: #8b5cf6;
            background: rgba(139, 92, 246, 0.05);
        }
        .no-scrollbar::-webkit-scrollbar { display: none; }
    </style>
</head>
<body class="bg-[#05020a] text-white overflow-hidden selection:bg-purple-500/30">
    
    <canvas id="aurora-canvas"></canvas>

    <div class="fixed inset-0 flex items-center justify-center p-4 z-10">
        <div class="w-full max-w-[1000px] h-[650px] md:h-[600px] glass rounded-[2.5rem] overflow-hidden relative shadow-[0_0_50px_rgba(0,0,0,0.5)]">
            
            <div id="formWrapper" class="wrapper h-full">
                
                <!-- LOGIN SECTION -->
                <div class="form-panel h-full">
                    <!-- Left: Form -->
                    <div class="w-full md:w-[50%] flex flex-col justify-center px-10 md:px-16 py-8 h-full">
                        <div class="mb-8 text-center md:text-left">
                            <span class="text-xs font-bold tracking-[0.3em] text-indigo-400 uppercase">AVI PORTAL</span>
                            <h1 class="text-3xl md:text-4xl font-extrabold mt-2 mb-2 bg-clip-text text-transparent bg-gradient-to-r from-white to-gray-400">Welcome Back</h1>
                            <p class="text-white/40 text-sm">Please login to your account</p>
                        </div>

                        <!-- LOGIN FORM -->
                        <form id="loginForm" autocomplete="off" class="space-y-6">
                            <div class="relative group">
                                <input type="email" name="email" placeholder="Email Address"
                                       class="loginInput input-field w-full px-5 py-4 rounded-2xl text-white placeholder-white/20 outline-none" required>
                            </div>

                            <div class="group relative">
                                <input type="password" id="loginPass" name="password" placeholder="Password"
                                       class="loginInput input-field w-full px-5 py-4 pr-12 rounded-2xl text-white placeholder-white/20 outline-none" required>
                                <button type="button" onclick="togglePassword('loginPass','eye1')"
                                    class="absolute right-4 top-1/2 -translate-y-1/2 text-white/30 hover:text-indigo-400 transition-colors">
                                    <i id="eye1" class="fa-solid fa-eye-slash"></i>
                                </button>
                            </div>

                            <div class="flex justify-end">
                                <a id="forgotBtn" class="text-xs font-bold text-indigo-400 hover:text-indigo-300 uppercase tracking-widest cursor-pointer">Forgot Password?</a>
                            </div>

                           <button type="submit"
class="w-full bg-gradient-to-r from-purple-600 to-pink-600 
hover:scale-[1.02] active:scale-[0.95] 
text-white font-bold py-4 rounded-2xl 
shadow-lg mt-4 transition-all duration-300">
Login
</button>

                            <div class="flex flex-col items-center gap-4 mt-6">
                                <p class="text-sm text-white/40">Don't have an account? 
                                    <button type="button" onclick="showRegister()" 
                                        class="text-white font-bold hover:text-indigo-400 ml-1 transition-colors underline decoration-indigo-500/30">Sign Up</button>
                                </p>
                                
                                <div class="w-full h-[1px] bg-white/5 relative my-2">
                                    <span class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 bg-[#0c0914] px-4 text-[10px] text-white/20 font-bold uppercase tracking-widest">or</span>
                                </div>

                                <div class="flex items-center justify-center gap-2 text-[13px]">
                                    <span class="text-white/30">You are an admin?</span>
                                    <a href="/admin/login" class="flex items-center gap-1.5 text-white/40 hover:text-indigo-400 transition font-normal">
                                        <i class="fa-solid fa-shield-halved text-[11px]"></i> Login
                                    </a>
                                </div>
                            </div>
                        </form>
                    </div>

                    <!-- Right: Visual -->
                    <div class="hidden md:block w-[50%] h-full relative">
                        <img src="https://images.unsplash.com/photo-1523240795612-9a054b0db644?q=80&w=1470&auto=format&fit=crop" class="absolute inset-0 w-full h-full object-cover brightness-50">
                        <div class="absolute inset-0 bg-gradient-to-l from-[#05020a] via-[#05020a]/40 to-transparent"></div>
                        <div class="absolute inset-0 flex items-center justify-center p-12">
                            <div class="w-full aspect-square gradient-border rounded-[3rem] animate-float flex items-center justify-center overflow-hidden">
                                <div class="text-center p-8">
                                    <div class="w-20 h-20 mx-auto bg-indigo-500/10 rounded-full flex items-center justify-center border border-indigo-500/20 mb-6 animate-login-pulse">
                                        <i class="fa-solid fa-graduation-cap text-3xl text-indigo-400"></i>
                                    </div>
                                    <h2 class="text-2xl font-bold mb-2 text-white">AVI Portal</h2>
                                    <p class="text-white/40 text-sm">Secure Academic Access</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- REGISTER SECTION -->
                <div class="form-panel h-full">
                    <!-- Left: Visual -->
                    <div class="hidden md:block w-[50%] h-full relative">
                        <img src="https://images.unsplash.com/photo-1517486808906-6ca8b3f04846?q=80&w=1498&auto=format&fit=crop" class="absolute inset-0 w-full h-full object-cover brightness-50">
                        <div class="absolute inset-0 bg-gradient-to-r from-[#05020a] via-[#05020a]/40 to-transparent"></div>
                        <div class="absolute inset-0 flex items-center justify-center p-12">
                            <div class="w-full aspect-square gradient-border rounded-[3rem] animate-float flex items-center justify-center overflow-hidden" style="animation-delay: -3s">
                                <div class="text-center p-8">
                                    <div class="w-20 h-20 mx-auto bg-pink-500/10 rounded-full flex items-center justify-center border border-pink-500/20 mb-6 animate-login-pulse">
                                        <i class="fa-solid fa-user-plus text-3xl text-pink-400"></i>
                                    </div>
                                    <h2 class="text-2xl font-bold mb-2 text-white">Join Us</h2>
                                    <p class="text-white/40 text-sm">Start your student journey</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Right: Form -->
                    <div class="w-full md:w-[50%] flex flex-col justify-center px-10 md:px-16 py-8 h-full overflow-y-auto no-scrollbar">
                        <div class="mb-6 pt-10 md:pt-0">
                            <h1 class="text-3xl font-extrabold mb-1">Create Account</h1>
                            <p class="text-white/40 text-sm">Join the student community</p>
                        </div>

                        <form action="/auth/register" method="POST" autocomplete="off" class="space-y-4 pb-10">
                            <input type="text" name="fullname" placeholder="Full Name" class="regInput input-field w-full px-5 py-3.5 rounded-2xl text-white placeholder-white/20 outline-none" required>
                            <input type="email" name="email" placeholder="Email Address" class="regInput input-field w-full px-5 py-3.5 rounded-2xl text-white placeholder-white/20 outline-none" required>
                            <input type="text" name="admissionNumber" placeholder="Admission No" class="regInput input-field w-full px-5 py-3.5 rounded-2xl text-white placeholder-white/20 outline-none" required>
                            
                            <div class="relative">
                                <input type="password" id="regPass" name="password" placeholder="Password" class="regInput input-field w-full px-5 py-3.5 pr-12 rounded-2xl text-white placeholder-white/20 outline-none" required>
                                <button type="button" onclick="togglePassword('regPass','eye2')" class="absolute right-4 top-1/2 -translate-y-1/2 text-white/30"><i id="eye2" class="fa-solid fa-eye-slash"></i></button>
                            </div>

                            <div class="relative">
                                <input type="password" id="regCPass" name="confirmPassword" placeholder="Confirm Password" class="regInput input-field w-full px-5 py-3.5 pr-12 rounded-2xl text-white placeholder-white/20 outline-none" required>
                                <button type="button" onclick="togglePassword('regCPass','eye3')" class="absolute right-4 top-1/2 -translate-y-1/2 text-white/30"><i id="eye3" class="fa-solid fa-eye-slash"></i></button>
                            </div>

                            <button type="button" onclick="submitRegisterForm()" class="w-full bg-gradient-to-r from-purple-600 to-pink-600 hover:scale-[1.02] text-white font-bold py-4 rounded-2xl shadow-lg mt-4 transition-all active:scale-95">
                                Sign Up
                            </button>

                            <p class="text-center text-sm text-white/40 mt-6">
                                Already a student? 
                                <button type="button" onclick="showLogin()" class="text-white font-bold hover:text-indigo-400 ml-1 transition-colors underline decoration-indigo-500/30">Login here</button>
                            </p>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- OTP POPUP (Targeted by script.js) -->
<div id="otpPopup"
class="fixed inset-0 bg-black/80 backdrop-blur-2xl flex items-center justify-center 
opacity-0 pointer-events-none transition-all duration-500 z-[999] p-4">

    <div id="otpCard"
    class="relative bg-gradient-to-br from-[#1e1b4b]/80 to-[#020617]/80 
    w-full max-w-sm rounded-[2.5rem] p-10 
    border border-purple-500/20 
    scale-95 transition-all duration-500 
    shadow-[0_20px_60px_rgba(139,92,246,0.25)]">

        <!-- Glow Effect -->
        <div class="absolute -top-10 -right-10 w-40 h-40 bg-purple-600/30 blur-[100px] rounded-full"></div>

        <!-- Close -->
        <button onclick="closeOtpPopup()"
        class="absolute right-8 top-8 text-gray-400 hover:text-purple-400 text-2xl transition">
            &times;
        </button>

        <!-- Icon -->
        <div class="relative w-16 h-16 bg-purple-500/20 border border-purple-500/30 
        rounded-full mx-auto flex items-center justify-center mb-6 animate-pulse">
            <img src="https://cdn-icons-png.flaticon.com/512/561/561127.png"
            class="w-8 opacity-90 invert">
        </div>

        <!-- Title -->
        <h2 class="text-white text-2xl font-bold text-center">
            Check your email
        </h2>

        <p class="text-gray-400 text-sm text-center mt-1">
            Enter the verification code sent to
        </p>

        <p id="otpEmail"
        class="text-purple-400 text-sm font-medium text-center mb-6"></p>

        <!-- OTP Boxes -->
        <div class="flex justify-center gap-2 mb-6">
            <input maxlength="1" class="otpBox w-11 h-12 bg-white/5 border border-white/10 rounded-xl text-center text-xl font-bold text-white focus:border-purple-500 focus:ring-2 focus:ring-purple-500/30 outline-none transition-all">
            <input maxlength="1" class="otpBox w-11 h-12 bg-white/5 border border-white/10 rounded-xl text-center text-xl font-bold text-white focus:border-purple-500 focus:ring-2 focus:ring-purple-500/30 outline-none transition-all">
            <input maxlength="1" class="otpBox w-11 h-12 bg-white/5 border border-white/10 rounded-xl text-center text-xl font-bold text-white focus:border-purple-500 focus:ring-2 focus:ring-purple-500/30 outline-none transition-all">
            <input maxlength="1" class="otpBox w-11 h-12 bg-white/5 border border-white/10 rounded-xl text-center text-xl font-bold text-white focus:border-purple-500 focus:ring-2 focus:ring-purple-500/30 outline-none transition-all">
            <input maxlength="1" class="otpBox w-11 h-12 bg-white/5 border border-white/10 rounded-xl text-center text-xl font-bold text-white focus:border-purple-500 focus:ring-2 focus:ring-purple-500/30 outline-none transition-all">
            <input maxlength="1" class="otpBox w-11 h-12 bg-white/5 border border-white/10 rounded-xl text-center text-xl font-bold text-white focus:border-purple-500 focus:ring-2 focus:ring-purple-500/30 outline-none transition-all">
        </div>

        <!-- Resend -->
        <p class="text-gray-500 text-[11px] text-center mb-4">
            Didn’t get your code?
            <button id="resendBtn" disabled
            class="text-gray-600 font-medium cursor-not-allowed ml-1">
                Resend code in <span id="timer">120</span>s
            </button>
        </p>

        <!-- Verify Button -->
        <button id="verifyBtn"
        class="w-full bg-gradient-to-r from-purple-600 to-pink-600 
        hover:scale-[1.03] active:scale-[0.95] 
        text-white font-bold py-3.5 rounded-2xl 
        shadow-lg shadow-purple-500/30 
        transition-all duration-300">
            Verify email
        </button>

        <!-- Cancel -->
        <button onclick="closeOtpPopup()"
        class="w-full text-gray-400 text-xs mt-4 py-2 hover:text-purple-400 transition">
            Cancel
        </button>

        <!-- Success Msg -->
        <p id="otpMsg"
        class="text-center text-green-400 text-sm mt-4 hidden">
            Verified!
        </p>

    </div>
</div>
    <!-- FORGOT PASSWORD POPUP (Targeted by script.js) -->
<div id="forgotPopup"
class="fixed inset-0 bg-black/80 backdrop-blur-2xl flex items-center justify-center 
opacity-0 pointer-events-none transition-all duration-500 z-[999] p-4">

    <div id="forgotCard"
    class="relative bg-gradient-to-br from-[#1e1b4b]/80 to-[#020617]/80 
    w-full max-w-sm rounded-[2.5rem] p-10 
    border border-purple-500/20 
    scale-90 transition-all duration-500 
    shadow-[0_20px_60px_rgba(139,92,246,0.25)]">

        <!-- Glow Effect -->
        <div class="absolute -top-10 -left-10 w-40 h-40 bg-purple-600/30 blur-[100px] rounded-full"></div>

        <!-- Close -->
        <button onclick="closeForgotPopup()"
        class="absolute right-8 top-8 text-gray-400 hover:text-purple-400 text-2xl transition">
            &times;
        </button>

        <!-- Icon -->
        <div class="relative w-16 h-16 bg-purple-500/20 border border-purple-500/30 
        rounded-full mx-auto flex items-center justify-center mb-4 animate-pulse">
            <img src="https://cdn-icons-png.flaticon.com/512/3064/3064197.png"
            class="w-8 opacity-90 invert">
        </div>

        <!-- Title -->
        <h2 class="text-white text-2xl font-bold text-center">
            Forgot Password?
        </h2>

        <!-- Subtitle -->
        <p class="text-gray-400 text-sm text-center mt-1">
            Enter your email and we’ll send you an OTP to reset your password.
        </p>

        <!-- Input -->
        <input id="forgotEmail" type="email" placeholder="Enter your email"
        class="w-full bg-white/5 border border-white/10 rounded-2xl p-4 
        text-white placeholder-gray-500 outline-none 
        focus:border-purple-500 focus:ring-2 focus:ring-purple-500/30 
        transition my-6">

        <!-- Button -->
        <button id="forgotSendBtn"
        class="w-full bg-gradient-to-r from-purple-600 to-pink-600 
        hover:scale-[1.03] active:scale-[0.95] 
        text-white font-bold py-4 rounded-2xl 
        shadow-lg shadow-purple-500/30 
        transition-all duration-300">
            Send OTP
        </button>

        <!-- Message -->
        <p id="forgotMsg"
        class="text-center text-green-400 text-sm mt-4 hidden">
            OTP Sent!
        </p>

    </div>
</div>

