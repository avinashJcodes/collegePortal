<!DOCTYPE html>
<html>
<head>
  <title>Attendance</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>


<body class="bg-gradient-to-br from-[#0f0c29] via-[#1a1333] to-[#0b0b1a] text-white p-8">

<h1 class="text-3xl font-bold mb-6 text-purple-400 tracking-wide">
  Face Recognition Attendance
</h1>

<div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl overflow-hidden shadow-2xl">

<table class="w-full">
  <thead class="bg-white/10">
    <tr class="text-left text-sm uppercase tracking-wider text-purple-300">
      <th class="p-4">Student Name</th>
      <th class="p-4">Admission No</th>
      <th class="p-4">Date</th>
      <th class="p-4">Time</th>
      <th class="p-4">Status</th>
      <th class="p-4">Method</th>
    </tr>
  </thead>

  <tbody>

  <% if (records && records.length > 0) { %>

    <% records.forEach(r => { %>
      <tr class="border-t border-white/10 hover:bg-purple-500/10 transition">

        <td class="p-4 font-semibold text-purple-300">
          <%= r.studentId ? r.studentId.fullname : "Deleted Student" %>
        </td>

        <td class="p-4 text-gray-300">
          <%= r.studentId ? r.studentId.admissionNumber : "-" %>
        </td>

        <td class="p-4 text-gray-400"><%= r.date %></td>
        <td class="p-4 text-gray-400"><%= r.time || "-" %></td>

        <td class="p-4 font-semibold <%= r.status === 'Present' ? 'text-green-400' : 'text-red-400' %>">
          <%= r.status %>
        </td>

        <td class="p-4 text-indigo-300">
          <%= r.method %>
        </td>

      </tr>
    <% }) %>

  <% } else { %>

    <tr>
      <td colspan="6" class="p-8 text-center text-gray-500">
        No attendance records found
      </td>
    </tr>

  <% } %>

  </tbody>
</table>

</div>

</body>
</html>
