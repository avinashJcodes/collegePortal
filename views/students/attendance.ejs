<!DOCTYPE html>
<html>
<head>
  <title>Attendance</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<style>
/* LIGHT THEME */

body {
  background: #f9fafb !important;
  color: #1e293b !important;
}

.bg-slate-900 {
  background: #f9fafb !important;
}

.bg-slate-800 {
  background: #ffffff !important;
}

.border-white\/10 {
  border-color: #e5e7eb !important;
}

.text-white {
  color: #111827 !important;
}

.text-gray-300 {
  color: #4b5563 !important;
}

.text-gray-400 {
  color: #6b7280 !important;
}
</style>

<body class="bg-slate-900 text-white p-8">

<h1 class="text-3xl font-bold mb-6 text-green-400">
  Face Recognition Attendance
</h1>

<table class="w-full border border-white/10 rounded-xl overflow-hidden">
  <thead class="bg-slate-800">
    <tr class="text-left">
      <th class="p-3">Student Name</th>
      <th class="p-3">Admission No</th>
      <th class="p-3">Date</th>
      <th class="p-3">Time</th>
      <th class="p-3">Status</th>
      <th class="p-3">Method</th>
    </tr>
  </thead>

  <tbody>

  <% if (records && records.length > 0) { %>

    <% records.forEach(r => { %>
      <tr class="border-t border-white/10">

        <td class="p-3 font-semibold text-indigo-300">
          <%= r.studentId ? r.studentId.fullname : "Deleted Student" %>
        </td>

        <td class="p-3 text-gray-300">
          <%= r.studentId ? r.studentId.admissionNumber : "-" %>
        </td>

        <td class="p-3"><%= r.date %></td>
        <td class="p-3"><%= r.time || "-" %></td>

        <td class="p-3 font-semibold <%= r.status === 'Present' ? 'text-green-400' : 'text-red-400' %>">
          <%= r.status %>
        </td>

        <td class="p-3">
          <%= r.method %>
        </td>

      </tr>
    <% }) %>

  <% } else { %>

    <tr>
      <td colspan="6" class="p-6 text-center text-gray-400">
        No attendance records found
      </td>
    </tr>

  <% } %>

  </tbody>
</table>

</body>
</html>
