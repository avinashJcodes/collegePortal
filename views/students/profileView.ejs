<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>My Profile | Student Portal</title>

<script src="https://cdn.tailwindcss.com"></script>
<script src="https://unpkg.com/lucide@latest"></script>

<style>
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');

body{
  font-family:'Inter',sans-serif;
  background:#f8fafc; /* light gray */
  color:#1e293b;
}
.glass-card{
  background:#ffffff;
  border:1px solid #e2e8f0;
  box-shadow:0 10px 25px rgba(0,0,0,0.05);
}

.detail-item{
  background:#f1f5f9;
  border:1px solid #e2e8f0;
}

.section-header{
  display:flex;
  align-items:center;
  gap:.75rem;
  margin-bottom:1.25rem;
  padding-bottom:.75rem;
  border-bottom:1px solid rgba(255,255,255,.08);
}
</style>
</head>

<body class="text-slate-700">

<div class="max-w-6xl mx-auto px-6 py-10">

<!-- HEADER -->
<div class="flex items-center justify-between mb-10 border-b border-slate-200 pb-6">
  <div>
    <h1 class="text-2xl font-semibold text-slate-800">Student Profile</h1>
    <p class="text-sm text-slate-400 mt-1">Official Academic Identity Record</p>
  </div>

  <a href="/student/profile?edit=true"
     class="bg-indigo-600 hover:bg-indigo-500 px-5 py-2 rounded-lg text-sm font-semibold text-slate-800 flex items-center gap-2">
    <i data-lucide="edit" class="w-4 h-4"></i>
    update Profile
  </a>
</div>

<!-- ================= IDENTITY CARD ================= -->
<section class="glass-card rounded-xl p-6 mb-8">
  <div class="flex flex-col md:flex-row md:items-center gap-6">
    <img
      src="<%= student.profileImage || 'https://ui-avatars.com/api/?background=6366f1&color=fff&size=200&name=' + student.fullname %>"
      class="w-28 h-28 rounded-full border-4 border-indigo-500/40 object-cover">

    <div>
      <h2 class="text-2xl font-bold "><%= student.fullname %></h2>
      <p class="text-indigo-500 text-sm font-semibold mt-1">
        <%= student.course || 'Course Not Selected' %>
      </p>

      <div class="flex gap-3 mt-3 text-xs">
        <span class="px-3 py-1 bg-slate-100 border  rounded-full">
          Student ID: <%= student.studentId || 'N/A' %>
        </span>
        <span class="px-3 py-1 bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 rounded-full">
          Active
        </span>
      </div>
    </div>
  </div>
</section>

<!-- ================= PERSONAL ================= -->
<section class="glass-card rounded-xl p-6 mb-8">
<div class="section-header">
  <i data-lucide="user" class="w-5 h-5 text-indigo-400"></i>
  <h3 class="text-lg font-semibold text-slate-800">01 · Personal Details</h3>
</div>

<div class="grid md:grid-cols-2 gap-4">
  <div class="detail-item p-4 rounded-lg">
    <p class="text-xs text-slate-400">Email</p>
    <p class="font-medium"><%= student.email %></p>
  </div>

  <div class="detail-item p-4 rounded-lg">
    <p class="text-xs text-slate-400">Contact</p>
    <p class="font-medium"><%= student.phone || 'Not Provided' %></p>
  </div>

  <div class="detail-item p-4 rounded-lg">
    <p class="text-xs text-slate-400">Date of Birth</p>
    <p class="font-medium"><%= student.dob ? student.dob.toDateString() : 'Not Set' %></p>
  </div>

  <div class="detail-item p-4 rounded-lg">
    <p class="text-xs text-slate-400">Gender</p>
    <p class="font-medium"><%= student.gender || 'N/A' %></p>
  </div>

  <div class="detail-item p-4 rounded-lg">
    <p class="text-xs text-slate-400">Blood Group</p>
    <p class="font-medium"><%= student.bloodGroup || 'N/A' %></p>
  </div>

  <div class="detail-item p-4 rounded-lg">
    <p class="text-xs text-slate-400">Aadhar</p>
    <p class="font-mono tracking-widest"><%= student.aadharNumber || 'XXXX XXXX XXXX' %></p>
  </div>
</div>
</section>

<!-- ================= ACADEMIC ================= -->
<section class="glass-card rounded-xl p-6 mb-8">
<div class="section-header">
  <i data-lucide="graduation-cap" class="w-5 h-5 text-cyan-400"></i>
  <h3 class="text-lg font-semibold text-slate-800">02 · Academic Details</h3>
</div>

<div class="grid md:grid-cols-2 gap-4">
  <div class="detail-item p-4 rounded-lg md:col-span-2">
    <p class="text-xs text-slate-400">Course</p>
    <p class="font-semibold text-cyan-400"><%= student.course || 'N/A' %></p>
  </div>

  <div class="detail-item p-4 rounded-lg">
    <p class="text-xs text-slate-400">Course Code</p>
    <p class="font-mono"><%= student.courseCode || 'N/A' %></p>
  </div>

  <div class="detail-item p-4 rounded-lg">
    <p class="text-xs text-slate-400">Roll Number</p>
    <p class="font-semibold"><%= student.rollNumber || 'N/A' %></p>
  </div>

  <div class="detail-item p-4 rounded-lg">
    <p class="text-xs text-slate-400">Semester</p>
    <p>Semester <%= student.semester || 'N/A' %></p>
  </div>

  <div class="detail-item p-4 rounded-lg">
    <p class="text-xs text-slate-400">ABC ID</p>
    <p class="font-mono tracking-widest"><%= student.abcId || 'N/A' %></p>
  </div>
</div>
</section>

<!-- ================= EDUCATION ================= -->
<section class="glass-card rounded-xl p-6 mb-8">
<div class="section-header">
  <i data-lucide="history" class="w-5 h-5 text-amber-400"></i>
  <h3 class="text-lg font-semibold text-slate-800">03 · Education History</h3>
</div>

<div class="grid md:grid-cols-2 gap-4">
  <div class="detail-item p-4 rounded-lg">
    <p class="text-xs text-slate-400">10th Board</p>
    <p><%= student.tenthBoard || 'N/A' %></p>
  </div>

  <div class="detail-item p-4 rounded-lg">
    <p class="text-xs text-slate-400">10th Score</p>
    <p><%= student.tenthScore || 'N/A' %></p>
  </div>

  <div class="detail-item p-4 rounded-lg">
    <p class="text-xs text-slate-400">12th Board</p>
    <p><%= student.twelfthBoard || 'N/A' %></p>
  </div>

  <div class="detail-item p-4 rounded-lg">
    <p class="text-xs text-slate-400">12th Score</p>
    <p><%= student.twelfthScore || 'N/A' %></p>
  </div>
</div>
</section>

<!-- ================= FAMILY & ADDRESS ================= -->
<section class="glass-card rounded-xl p-6">
<div class="section-header">
  <i data-lucide="users" class="w-5 h-5 text-rose-400"></i>
  <h3 class="text-lg font-semibold text-slate-800">04 · Family & Address</h3>
</div>

<div class="space-y-4">
  <div class="grid md:grid-cols-2 gap-4">
    <div class="detail-item p-4 rounded-lg">
      <p class="text-xs text-slate-400">Father</p>
      <p><%= student.fatherName || 'N/A' %></p>
    </div>

    <div class="detail-item p-4 rounded-lg">
      <p class="text-xs text-slate-400">Mother</p>
      <p><%= student.motherName || 'N/A' %></p>
    </div>
  </div>

  <div class="detail-item p-4 rounded-lg">
    <p class="text-xs text-slate-400">Address</p>
    <p class="leading-relaxed"><%= student.address || 'Not Provided' %></p>
  </div>

  <div class="detail-item p-4 rounded-lg">
    <p class="text-xs text-slate-400">Emergency Contact</p>
    <p class="font-semibold text-rose-400"><%= student.guardianPhone || 'N/A' %></p>
  </div>
</div>
</section>

<p class="text-center text-slate-600 text-xs tracking-widest mt-10">
NEXUS STUDENT INFORMATION SYSTEM • SECURE DATABASE
</p>

</div>

<script>
lucide.createIcons();
</script>

</body>
</html>
