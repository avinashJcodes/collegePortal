<div class="min-h-screen flex items-center justify-center 
  <%= status === 'valid' || status === 'success'
    ? 'bg-gradient-to-br from-green-900 to-black' 
    : status === 'used' || status === 'expired' || status === 'invalid' 
    ? 'bg-gradient-to-br from-red-900 to-black' 
    : 'bg-gradient-to-br from-yellow-900 to-black' %> 
  text-white">

  <div class="w-full max-w-md p-6 rounded-2xl 
              bg-black/40 backdrop-blur-xl border border-white/10 
              shadow-2xl text-center">

    <!-- ================= VALID ================= -->
    <% if (status === "valid") { %>

      <div class="text-5xl mb-3">✅</div>

      <h1 class="text-3xl text-green-400 font-bold mb-3">
        Valid Gate Pass
      </h1>

      <!-- 🔥 STUDENT INFO -->
      <div class="bg-white/5 border border-white/10 rounded-xl p-4 mb-3 text-left">

        <p class="text-sm text-slate-400">Student Name</p>
        <p class="text-lg text-white font-semibold mb-2">
          <%= pass.studentId.fullname %>
        </p>

        <p class="text-sm text-slate-400">Pass ID</p>
        <p class="text-white mb-2"><%= pass.passId %></p>

        <% if (pass.studentId.rollNumber) { %>
          <p class="text-sm text-slate-400">Roll Number</p>
          <p class="text-white"><%= pass.studentId.rollNumber %></p>
        <% } %>

      </div>

      <!-- 🔥 PASS DETAILS -->
      <div class="bg-white/5 border border-white/10 rounded-xl p-4 mb-3 text-left">

        <p class="text-sm text-slate-400">Reason</p>
        <p class="text-white mb-2"><%= pass.reason %></p>

        <p class="text-sm text-slate-400">From</p>
        <p class="text-white mb-2">
          <%= new Date(pass.from).toLocaleString() %>
        </p>

        <p class="text-sm text-slate-400">To</p>
        <p class="text-white">
          <%= new Date(pass.to).toLocaleString() %>
        </p>

      </div>

      <!-- 🔥 ACTION BUTTON -->
      <form action="/verify-pass/use/<%= pass.passId %>" method="POST">
        <button class="mt-3 w-full py-3 rounded-lg font-semibold text-lg
                       bg-green-500 hover:bg-green-600 transition shadow-lg">
          ✔ Allow Entry
        </button>
      </form>

    <% } %>

 
<% if (status === "success") { %>

  <div class="text-5xl mb-3">✅</div>

  <h1 class="text-3xl text-green-400 font-bold">
    Pass Used Successfully
  </h1>

  <p class="text-sm text-slate-300 mt-2">
    Entry allowed — do not reuse this pass
  </p>

<% } %>


    <!-- ================= USED ================= -->
    <% if (status === "used") { %>

      <div class="text-5xl mb-3">❌</div>

      <h1 class="text-3xl text-red-400 font-bold">
        Pass Already Used
      </h1>

      <p class="text-sm text-slate-300 mt-2">
        Entry already taken — do not allow 
      </p>

    <% } %>


    <!-- ================= EXPIRED ================= -->
    <% if (status === "expired") { %>

      <div class="text-5xl mb-3">❌</div>

      <h1 class="text-3xl text-red-400 font-bold">
        Pass Expired
      </h1>

      <p class="text-sm text-slate-300 mt-2">
        This pass is no longer valid
      </p>

    <% } %>


    <!-- ================= INVALID ================= -->
    <% if (status === "invalid") { %>

      <div class="text-5xl mb-3">❌</div>

      <h1 class="text-3xl text-red-400 font-bold">
        Invalid Pass
      </h1>

      <p class="text-sm text-slate-300 mt-2">
        No record found — possible fake QR
      </p>

    <% } %>




    <!-- ================= NOT APPROVED ================= -->
    <% if (status === "not-approved") { %>

      <div class="text-5xl mb-3">⏳</div>

      <h1 class="text-3xl text-yellow-400 font-bold">
        Not Approved Yet
      </h1>

      <p class="text-sm text-slate-300 mt-2">
        Waiting for admin approval
      </p>

    <% } %>

  </div>

</div>